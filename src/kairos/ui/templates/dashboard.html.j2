{% extends "base.html.j2" %}
{% set active = "dashboard" %}
{% block title %}Overview{% endblock %}
{% block content %}

{# ── Helpers ─────────────────────────────────────────────────────── #}
{%- set action_labels = {
  "noop": "No-op",
  "horizontal_up": "Scale out",
  "horizontal_down": "Scale in",
  "vertical_up": "CPU/mem ↑",
  "vertical_down": "CPU/mem ↓",
  "node_pool_advisory": "Node pool advisory",
  "keda_prescale": "KEDA pre-scale",
  "human_approval_required": "Needs approval",
} -%}
{%- set action_colors = {
  "noop": "from-slate-400/30 to-slate-500/30",
  "horizontal_up": "from-emerald-400/40 to-teal-500/40",
  "horizontal_down": "from-sky-400/40 to-blue-500/40",
  "vertical_up": "from-amber-400/40 to-orange-500/40",
  "vertical_down": "from-cyan-400/40 to-sky-500/40",
  "node_pool_advisory": "from-violet-400/40 to-fuchsia-500/40",
  "keda_prescale": "from-indigo-400/40 to-blue-500/40",
  "human_approval_required": "from-rose-400/40 to-pink-500/40",
} -%}
{%- set status_colors = {
  "pending": "from-amber-400/40 to-orange-500/40",
  "approved": "from-emerald-400/40 to-teal-500/40",
  "rejected": "from-rose-400/40 to-pink-500/40",
  "applied": "from-blue-400/40 to-cyan-500/40",
  "merged": "from-violet-400/40 to-fuchsia-500/40",
  "expired": "from-slate-400/40 to-zinc-500/40",
  "failed": "from-red-400/40 to-rose-500/40",
} -%}
{%- set alert_colors = {
  "firing": "from-rose-400/40 to-red-500/40",
  "resolved": "from-emerald-400/40 to-teal-500/40",
  "acknowledged": "from-amber-400/40 to-orange-500/40",
} -%}

{# ── Header — single primary CTA ──────────────────────────────── #}
<header class="flex flex-col md:flex-row md:items-end md:justify-between mb-10" style="gap: var(--space-5);">
  <div>
    <div class="t-eyebrow flex items-center gap-2" style="margin-bottom: var(--space-2);">
      <span class="w-1.5 h-1.5 rounded-full" style="background: var(--success); box-shadow: 0 0 10px rgba(52,211,153,0.7);" aria-hidden="true"></span>
      Overview · {{ settings.environment }}
    </div>
    <h1 class="t-h1" style="margin: 0;">Activity</h1>
    <p class="t-body" style="color: var(--fg-dim); max-width: 60ch; margin: var(--space-2) 0 0;">
      Last 7 days at a glance. Trigger a run to refresh forecasts; jump into Pending to act on what needs review.
    </p>
  </div>
  <div class="flex flex-wrap items-center" style="gap: var(--space-2);">
    <button
      hx-post="/api/v1/runs"
      hx-vals='{"dry_run": true}'
      hx-headers='{"Content-Type": "application/json"}'
      hx-swap="none"
      hx-on::after-request="setTimeout(()=>window.location.reload(),700)"
      class="btn btn-primary">
      <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12l5 5L20 7"/></svg>
      Trigger run
    </button>
    <a href="/ui/pending" class="btn btn-sm">
      Pending
      {% if counters.pending_approvals > 0 %}
        <span class="num pill pill-warn" style="margin-left: var(--space-1); padding: 0 6px;" aria-label="{{ counters.pending_approvals }} pending">{{ counters.pending_approvals }}</span>
      {% endif %}
    </a>
    <a href="/ui/alerts" class="btn btn-sm">
      Alerts
      {% if (counters.alerts_firing or 0) > 0 %}
        <span class="num pill pill-danger" style="margin-left: var(--space-1); padding: 0 6px;" aria-label="{{ counters.alerts_firing }} firing">{{ counters.alerts_firing }}</span>
      {% endif %}
    </a>
    {% if grafana_url %}<a href="{{ grafana_url }}" target="_blank" rel="noopener" class="btn btn-sm" aria-label="Open Grafana (new tab)">Grafana</a>{% endif %}
  </div>
</header>

{# ── Snapshot counters ──────────────────────────────────────── #}
<section aria-labelledby="snap-title" class="mb-12">
  <h2 id="snap-title" class="t-eyebrow" style="margin-bottom: var(--space-4);">Live snapshot · today</h2>
  <div class="grid grid-cols-2 md:grid-cols-4" style="gap: var(--space-4);">
    {% set tiles = [
      {"label":"Pending",          "value": counters.pending_approvals,    "href":"/ui/pending", "color": "amber" if counters.pending_approvals > 0 else "neutral"},
      {"label":"Decisions today",  "value": counters.decisions_today,      "href":"/ui/history", "color":"neutral"},
      {"label":"PRs today",        "value": counters.prs_today,            "href":"/ui/history", "color":"neutral"},
      {"label":"Alerts firing",    "value": counters.alerts_firing or 0,   "href":"/ui/alerts",  "color": "rose" if (counters.alerts_firing or 0) > 0 else "neutral"},
    ] %}
    {% for t in tiles %}
    <a href="{{ t.href }}" class="glass block" style="padding: var(--space-4); text-decoration: none; color: inherit;">
      <div class="t-eyebrow flex items-center justify-between" style="margin-bottom: var(--space-2);">
        <span>{{ t.label }}</span>
        <svg viewBox="0 0 24 24" class="w-3 h-3" style="color: var(--fg-faint);" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </div>
      <div class="num"
           style="font-size: var(--text-xl); font-weight: 700; line-height: 1; letter-spacing: -0.04em;
                  color: {% if t.color == 'amber' %}var(--warn-fg){% elif t.color == 'rose' %}var(--danger-fg){% else %}var(--fg){% endif %};">
        {{ t.value }}
      </div>
    </a>
    {% endfor %}
  </div>
</section>

{# ── Activity (7-day) ──────────────────────────────────────── #}
<section aria-labelledby="activity-title" class="mb-12">
  <div class="flex items-center justify-between" style="margin-bottom: var(--space-4);">
    <h2 id="activity-title" class="t-eyebrow" style="margin: 0;">Application activity · last 7 days</h2>
    <a href="/ui/history" class="t-body-sm" style="color: var(--brand);">View full history →</a>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3" style="gap: var(--space-4);">
    {# Decisions per day #}
    {% set max_dec = (activity.decisions_per_day | map(attribute='count') | max) or 1 %}
    {% set total_dec = activity.decisions_per_day | sum(attribute='count') %}
    <a href="/ui/history" class="glass block" style="padding: var(--space-5); text-decoration: none; color: inherit;"
       aria-label="Decisions per day chart, {{ total_dec }} total over the last 7 days">
      <div class="t-eyebrow" style="margin-bottom: var(--space-1);">Decisions per day</div>
      <div class="num" style="font-size: var(--text-xl); font-weight: 700; line-height: 1; margin-bottom: var(--space-3);">{{ total_dec }}</div>
      <div class="flex items-end" style="gap: 4px; height: 80px;" role="img"
           aria-label="Bar chart, {{ activity.decisions_per_day | length }} days">
        {% for d in activity.decisions_per_day %}
        <div class="flex-1 flex flex-col items-center" style="gap: 4px;" title="{{ d.day }}: {{ d.count }} decisions">
          <div style="width: 100%; min-height: 2px; border-radius: 3px 3px 0 0;
                      background: linear-gradient(180deg, rgba(34,211,238,0.85), rgba(96,165,250,0.55));
                      height: {{ ((d.count / max_dec) * 100) if max_dec > 0 else 0 }}%;"></div>
          <div class="num" style="font-size: 10px; color: var(--fg-faint);">{{ d.day[5:] }}</div>
        </div>
        {% endfor %}
      </div>
    </a>

    {# Decision actions breakdown — horizontal bars #}
    {% set max_act = (activity.actions_breakdown | map(attribute='count') | max) or 1 %}
    {% set total_act = activity.actions_breakdown | sum(attribute='count') %}
    <a href="/ui/history" class="glass block" style="padding: var(--space-5); text-decoration: none; color: inherit;"
       aria-label="Decision actions breakdown, {{ total_act }} total">
      <div class="t-eyebrow" style="margin-bottom: var(--space-1);">Decision actions</div>
      <div class="num" style="font-size: var(--text-xl); font-weight: 700; line-height: 1; margin-bottom: var(--space-3);">{{ total_act }}</div>
      <div class="space-y-2">
        {% for a in activity.actions_breakdown[:5] %}
        <div>
          <div class="flex items-baseline justify-between" style="margin-bottom: 4px;">
            <span class="t-body-sm">{{ action_labels.get(a.action, a.action) }}</span>
            <span class="num t-caption">{{ a.count }}</span>
          </div>
          <div style="height: 6px; border-radius: 4px; background: rgba(255,255,255,0.05); overflow: hidden;">
            <div style="height: 100%; border-radius: 4px;
                        background: linear-gradient(90deg, rgba(96,165,250,0.55), rgba(34,211,238,0.85));
                        width: {{ (a.count / max_act) * 100 }}%;"></div>
          </div>
        </div>
        {% else %}
        <div class="t-body-sm" style="color: var(--fg-faint); padding: var(--space-4) 0; text-align: center;">No decisions yet — trigger a run.</div>
        {% endfor %}
      </div>
    </a>

    {# State breakdowns stacked #}
    <div class="grid grid-rows-2" style="gap: var(--space-4);">
      <a href="/ui/pending" class="glass block" style="padding: var(--space-4); text-decoration: none; color: inherit;">
        <div class="t-eyebrow flex items-center justify-between" style="margin-bottom: var(--space-2);">
          <span>Approvals by state</span>
          <svg viewBox="0 0 24 24" class="w-3 h-3" style="color: var(--fg-faint);" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
        <div class="flex flex-wrap" style="gap: 6px;">
          {% for a in activity.approvals_breakdown %}
          <span class="num" style="display: inline-flex; align-items: center; gap: 6px;
                                    padding: 2px 8px; border-radius: var(--radius-sm);
                                    background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
                                    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.10);
                                    font-size: var(--text-xs);">
            <span style="color: var(--fg-dim);">{{ a.status }}</span>
            <strong>{{ a.count }}</strong>
          </span>
          {% else %}
          <span class="t-caption">No approval history yet.</span>
          {% endfor %}
        </div>
      </a>
      <a href="/ui/alerts" class="glass block" style="padding: var(--space-4); text-decoration: none; color: inherit;">
        <div class="t-eyebrow flex items-center justify-between" style="margin-bottom: var(--space-2);">
          <span>Alerts by state</span>
          <svg viewBox="0 0 24 24" class="w-3 h-3" style="color: var(--fg-faint);" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
        <div class="flex flex-wrap" style="gap: 6px;">
          {% for a in activity.alerts_breakdown %}
          <span class="num" style="display: inline-flex; align-items: center; gap: 6px;
                                    padding: 2px 8px; border-radius: var(--radius-sm);
                                    background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
                                    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.10);
                                    font-size: var(--text-xs);">
            <span style="color: var(--fg-dim);">{{ a.state }}</span>
            <strong>{{ a.count }}</strong>
          </span>
          {% else %}
          <span class="t-caption">No alerts yet — Grafana will route them here.</span>
          {% endfor %}
        </div>
      </a>
    </div>
  </div>
</section>

{# ── Recent runs ──────────────────────────────────────────── #}
<section aria-labelledby="runs-title">
  <div class="flex items-center justify-between" style="margin-bottom: var(--space-3);">
    <h2 id="runs-title" class="t-eyebrow" style="margin: 0;">Recent pipeline runs</h2>
    <a href="/ui/history" class="t-body-sm" style="color: var(--brand);">View all →</a>
  </div>
  <div class="glass" style="overflow: hidden;">
    <table class="glass-table">
      <thead><tr><th>Run</th><th>Status</th><th class="text-right">Workloads</th><th>Started</th><th>Ended</th></tr></thead>
      <tbody>
        {% for r in recent_runs %}
        <tr style="cursor: pointer;" onclick="window.location='/ui/history'">
          <td class="mono t-caption">{{ r.id[:8] }}…</td>
          <td>
            <span class="pill {% if r.status == 'succeeded' %}pill-success{% elif r.status == 'partial' %}pill-warn{% elif r.status == 'failed' %}pill-danger{% else %}pill-info{% endif %}">
              <span class="w-1.5 h-1.5 rounded-full" style="background: currentColor; opacity: 0.7;" aria-hidden="true"></span>
              {{ r.status }}
            </span>
          </td>
          <td class="text-right num mono t-caption">{{ r.workloads_processed }}</td>
          <td class="mono t-caption">{{ r.started_at.strftime('%Y-%m-%d %H:%M') }}</td>
          <td class="mono t-caption">{{ r.ended_at.strftime('%H:%M:%S') if r.ended_at else '—' }}</td>
        </tr>
        {% else %}
        <tr><td colspan="5" style="text-align: center; padding: var(--space-7) var(--space-4); color: var(--fg-faint);">
          <div class="t-body">No runs yet — use &ldquo;Trigger run&rdquo; above.</div>
          <div class="t-caption mono" style="margin-top: var(--space-1);">POST /api/v1/runs</div>
        </td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

{% endblock %}
