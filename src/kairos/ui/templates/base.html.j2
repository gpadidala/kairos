<!doctype html>
<html lang="en" class="h-full" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark light" />
  <title>{% block title %}KAIROS{% endblock %} · KAIROS</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    /* ════════════════════════════════════════════════════════════════
       LINEAR / VERCEL VISUAL DIRECTION
       Sharp, flat, near-black. No glass blur. Single cyan accent.
       Bigger headlines (48-72px hero). Almost no shadows — borders
       carry the structure. Generous whitespace. Built on the
       ui-ux-pro-max token system (still 4/8 dp grid, type scale,
       a11y rules, motion tokens, prefers-reduced-motion).
    ═════════════════════════════════════════════════════════════════ */
    :root, [data-theme="dark"] {
      /* Near-black surface stack — Linear / Vercel signature */
      --bg-page: #0a0a0b;
      --bg-1: #0a0a0b;
      --bg-2: #0a0a0b;
      --bg-3: #0a0a0b;
      --surface: #111114;
      --surface-elevated: #16161a;
      --surface-raised: #1c1c22;
      --surface-overlay: rgba(10,10,11,0.85);

      /* Borders carry the structure (replaces glass blur) */
      --border: rgba(255,255,255,0.08);
      --border-strong: rgba(255,255,255,0.14);
      --border-focus: #4cc2ff;

      /* Foreground */
      --fg: #f4f4f5;
      --fg-dim: #a1a1aa;
      --fg-faint: #6b6b75;

      /* Single cyan/electric-blue accent */
      --brand: #4cc2ff;
      --brand-strong: #00aaff;
      --brand-fg: #0a0a0b;
      --brand-glow: 0 0 24px rgba(76,194,255,0.25);

      /* Semantic — muted, low-saturation */
      --info: #4cc2ff;
      --info-fg: #b8e8ff;
      --info-bg: rgba(76,194,255,0.10);
      --info-border: rgba(76,194,255,0.25);

      --success: #4ade80;
      --success-fg: #bbf7d0;
      --success-bg: rgba(74,222,128,0.10);
      --success-border: rgba(74,222,128,0.25);

      --warn: #facc15;
      --warn-fg: #fde68a;
      --warn-bg: rgba(250,204,21,0.10);
      --warn-border: rgba(250,204,21,0.25);

      --danger: #f87171;
      --danger-fg: #fca5a5;
      --danger-bg: rgba(248,113,113,0.10);
      --danger-border: rgba(248,113,113,0.30);

      /* Type scale — bigger on the high end */
      --text-xs: 12px;
      --text-sm: 13px;
      --text-base: 14px;
      --text-md: 15px;
      --text-lg: 18px;
      --text-xl: 24px;
      --text-2xl: 36px;
      --text-3xl: 56px;
      --text-4xl: 72px;
      --leading-body: 1.55;
      --leading-tight: 1.1;

      /* Spacing — 4/8 dp grid */
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 24px;
      --space-6: 32px;
      --space-7: 48px;
      --space-8: 64px;
      --space-9: 96px;

      /* Sharp radii — Linear/Vercel signature */
      --radius-xs: 4px;
      --radius-sm: 6px;
      --radius-md: 8px;
      --radius-lg: 10px;
      --radius-xl: 12px;

      /* Almost no elevation — borders do the work */
      --shadow-low:    0 1px 0 rgba(255,255,255,0.04) inset;
      --shadow-medium: 0 1px 0 rgba(255,255,255,0.06) inset;
      --shadow-high:   0 24px 48px -16px rgba(0,0,0,0.50);

      /* Motion */
      --motion-fast: 100ms;
      --motion-standard: 180ms;
      --motion-slow: 300ms;
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-in:  cubic-bezier(0.4, 0, 1, 1);

      /* Component */
      --focus-ring: 0 0 0 2px var(--bg-page), 0 0 0 4px rgba(76,194,255,0.55);
      --touch-min: 44px;
    }
    [data-theme="light"] {
      --bg-page: #fafafa;
      --bg-1: #fafafa;
      --bg-2: #fafafa;
      --bg-3: #fafafa;
      --surface: #ffffff;
      --surface-elevated: #ffffff;
      --surface-raised: #ffffff;
      --surface-overlay: rgba(250,250,250,0.85);
      --border: rgba(15,23,42,0.08);
      --border-strong: rgba(15,23,42,0.14);
      --fg: #0a0a0b;
      --fg-dim: #71717a;
      --fg-faint: #a1a1aa;
      --brand: #0066ff;
      --brand-strong: #0052cc;
      --brand-fg: #ffffff;
      --brand-glow: 0 0 24px rgba(0,102,255,0.20);
      --info-bg: rgba(0,102,255,0.08);
      --info-fg: #003d99;
      --info-border: rgba(0,102,255,0.20);
      --success-bg: rgba(34,197,94,0.10);
      --success-fg: #166534;
      --success-border: rgba(34,197,94,0.30);
      --warn-bg: rgba(234,179,8,0.12);
      --warn-fg: #854d0e;
      --warn-border: rgba(234,179,8,0.35);
      --danger-bg: rgba(239,68,68,0.10);
      --danger-fg: #991b1b;
      --danger-border: rgba(239,68,68,0.30);
      --shadow-low:    0 1px 2px rgba(15,23,42,0.04);
      --shadow-medium: 0 4px 12px -2px rgba(15,23,42,0.08);
      --shadow-high:   0 24px 48px -16px rgba(15,23,42,0.20);
      --focus-ring: 0 0 0 2px var(--bg-page), 0 0 0 4px rgba(0,102,255,0.40);
    }

    /* ── Reset + base ────────────────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    html, body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
      font-size: var(--text-base);
      line-height: var(--leading-body);
      letter-spacing: -0.011em;
      color: var(--fg);
      min-height: 100%;
    }
    body {
      background: var(--bg-page);
      background-attachment: fixed;
      /* Subtle vignette only — no radial color washes */
      background-image: radial-gradient(120% 80% at 50% 0%, rgba(76,194,255,0.04), transparent 60%);
    }

    /* Typography utilities */
    .mono { font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace; }
    .num  { font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1; }

    .t-display {
      font-size: clamp(48px, 8vw, var(--text-4xl));
      line-height: var(--leading-tight);
      font-weight: 700;
      letter-spacing: -0.045em;
    }
    .t-h1 { font-size: var(--text-2xl); line-height: var(--leading-tight); font-weight: 600; letter-spacing: -0.025em; }
    .t-h2 { font-size: var(--text-xl); line-height: 1.2; font-weight: 600; letter-spacing: -0.018em; }
    .t-h3 { font-size: var(--text-lg); line-height: 1.3; font-weight: 600; letter-spacing: -0.012em; }
    .t-body { font-size: var(--text-base); line-height: var(--leading-body); }
    .t-body-sm { font-size: var(--text-sm); line-height: 1.55; color: var(--fg-dim); }
    .t-caption { font-size: var(--text-xs); line-height: 1.45; color: var(--fg-dim); }
    .t-eyebrow {
      font-size: 11px; line-height: 1; letter-spacing: 0.06em;
      text-transform: uppercase; font-weight: 500; color: var(--fg-faint);
    }

    /* ── Surfaces (replaces glass) ───────────────────────────── */
    .glass, .surface {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-low);
      transition: border-color var(--motion-standard) var(--ease-out),
                  background var(--motion-standard) var(--ease-out);
    }
    .glass:hover, .surface:hover { border-color: var(--border-strong); }

    .glass-strong, .surface-elevated {
      background: var(--surface-elevated);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-medium);
    }

    /* ── Buttons ─────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      gap: var(--space-2);
      min-height: 36px;
      padding: 0 var(--space-4);
      border-radius: var(--radius-md);
      font-weight: 500; font-size: var(--text-sm); line-height: 1;
      letter-spacing: -0.005em;
      color: var(--fg);
      background: var(--surface-raised);
      border: 1px solid var(--border-strong);
      cursor: pointer;
      text-decoration: none;
      transition: background var(--motion-fast) var(--ease-out),
                  border-color var(--motion-fast) var(--ease-out),
                  color var(--motion-fast) var(--ease-out);
      touch-action: manipulation;
      white-space: nowrap;
    }
    .btn:hover {
      background: #22222a;
      border-color: rgba(255,255,255,0.20);
      text-decoration: none;
    }
    .btn:active { background: #1c1c22; transform: translateY(0.5px); }
    .btn:focus-visible { outline: none; box-shadow: var(--focus-ring); }
    .btn[disabled], .btn[aria-disabled="true"] { opacity: 0.45; cursor: not-allowed; }

    .btn-primary {
      background: var(--brand);
      color: var(--brand-fg);
      border-color: var(--brand);
      font-weight: 600;
    }
    .btn-primary:hover { background: var(--brand-strong); border-color: var(--brand-strong); }
    .btn-success {
      background: var(--success);
      color: #052e16;
      border-color: var(--success);
      font-weight: 600;
    }
    .btn-success:hover { background: #22c55e; border-color: #22c55e; }
    .btn-danger {
      background: var(--danger);
      color: #450a0a;
      border-color: var(--danger);
      font-weight: 600;
    }
    .btn-danger:hover { background: #ef4444; border-color: #ef4444; }
    .btn-sm { min-height: 28px; padding: 0 10px; font-size: var(--text-xs); border-radius: var(--radius-sm); }
    .btn-lg { min-height: 44px; padding: 0 var(--space-5); font-size: var(--text-md); }
    .btn-icon { min-height: 32px; min-width: 32px; padding: 0; place-items: center; }

    /* Backwards-compat shims (plain CSS — no @extend) */
    .btn-glass-sm      { min-height: 28px; padding: 0 10px; font-size: var(--text-xs); border-radius: var(--radius-sm);
                         display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2);
                         color: var(--fg); background: var(--surface-raised);
                         border: 1px solid var(--border-strong); cursor: pointer; text-decoration: none;
                         font-weight: 500; transition: background var(--motion-fast); white-space: nowrap; }
    .btn-glass-sm:hover { background: #22222a; }
    .btn-glass-success { background: var(--success); color: #052e16; border-color: var(--success); font-weight: 600; }
    .btn-glass-success:hover { background: #22c55e; border-color: #22c55e; }
    .btn-glass-danger  { background: var(--danger); color: #450a0a; border-color: var(--danger); font-weight: 600; }
    .btn-glass-danger:hover { background: #ef4444; border-color: #ef4444; }
    .btn-glass {
      display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2);
      min-height: 36px; padding: 0 var(--space-4);
      border-radius: var(--radius-md);
      font-weight: 500; font-size: var(--text-sm); color: var(--fg);
      background: var(--surface-raised);
      border: 1px solid var(--border-strong);
      cursor: pointer; text-decoration: none;
      transition: background var(--motion-fast), border-color var(--motion-fast);
      white-space: nowrap;
    }
    .btn-glass:hover { background: #22222a; border-color: rgba(255,255,255,0.20); }
    .btn-glass:focus-visible { outline: none; box-shadow: var(--focus-ring); }

    /* ── Pills / badges ─────────────────────────────────────── */
    .pill {
      display: inline-flex; align-items: center; gap: var(--space-1);
      padding: 2px 8px;
      min-height: 20px;
      border-radius: var(--radius-xs);
      font-size: 11px; font-weight: 500; line-height: 1;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      color: var(--fg-dim);
      white-space: nowrap;
    }
    .pill-info    { background: var(--info-bg);    border-color: var(--info-border);    color: var(--info-fg); }
    .pill-warn    { background: var(--warn-bg);    border-color: var(--warn-border);    color: var(--warn-fg); }
    .pill-danger  { background: var(--danger-bg);  border-color: var(--danger-border);  color: var(--danger-fg); }
    .pill-success { background: var(--success-bg); border-color: var(--success-border); color: var(--success-fg); }
    .pill-mono    { font-family: "JetBrains Mono", monospace; font-size: 11px; letter-spacing: 0; }

    /* ── Inputs ─────────────────────────────────────────────── */
    .glass-input {
      width: 100%; min-height: 36px;
      padding: var(--space-2) var(--space-3);
      background: var(--surface-raised);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-md);
      color: var(--fg); font-size: var(--text-sm);
      transition: border-color var(--motion-fast), background var(--motion-fast), box-shadow var(--motion-fast);
    }
    [data-theme="light"] .glass-input { background: #ffffff; }
    .glass-input::placeholder { color: var(--fg-faint); }
    .glass-input:focus, .glass-input:focus-visible {
      outline: none; border-color: var(--brand);
      box-shadow: 0 0 0 3px rgba(76,194,255,0.18);
    }

    /* ── Stat numbers ───────────────────────────────────────── */
    .stat-number {
      font-weight: 700; letter-spacing: -0.04em;
      font-size: var(--text-xl); line-height: 1;
      font-variant-numeric: tabular-nums;
      color: var(--fg);
    }

    /* ── Tables ─────────────────────────────────────────────── */
    .glass-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .glass-table th {
      font-weight: 500; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--fg-faint);
      padding: var(--space-3) var(--space-4); text-align: left;
      border-bottom: 1px solid var(--border);
      background: transparent;
    }
    .glass-table td {
      padding: var(--space-3) var(--space-4);
      border-bottom: 1px solid var(--border);
      font-size: var(--text-sm); color: var(--fg);
    }
    .glass-table tr:last-child td { border-bottom: none; }
    .glass-table tr:hover td { background: rgba(255,255,255,0.02); }

    /* ── Sidebar layout ─────────────────────────────────────── */
    .layout {
      display: grid;
      grid-template-columns: 232px 1fr;
      min-height: 100dvh;
    }
    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }
    .sidebar {
      position: sticky; top: 0; height: 100dvh;
      padding: var(--space-4) var(--space-3);
      background: var(--bg-page);
      border-right: 1px solid var(--border);
      overflow-y: auto;
    }
    .sidebar-section {
      font-size: 11px; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--fg-faint);
      padding: var(--space-5) var(--space-3) var(--space-2);
    }
    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      min-height: 32px;
      padding: 6px var(--space-3); border-radius: var(--radius-sm);
      color: var(--fg-dim); font-size: var(--text-sm); font-weight: 500;
      text-decoration: none;
      transition: color var(--motion-fast) var(--ease-out),
                  background var(--motion-fast) var(--ease-out);
    }
    .sidebar-link:hover { color: var(--fg); background: rgba(255,255,255,0.04); text-decoration: none; }
    .sidebar-link:focus-visible { outline: none; box-shadow: var(--focus-ring); }
    .sidebar-link[aria-current="page"], .sidebar-link.active {
      color: var(--fg);
      background: rgba(255,255,255,0.06);
      box-shadow: inset 2px 0 0 0 var(--brand);
    }
    .sidebar-link svg { width: 16px; height: 16px; opacity: 0.85; flex-shrink: 0; }
    .sidebar-link .badge {
      margin-left: auto;
      font-size: 10px; font-weight: 600;
      padding: 1px 6px; border-radius: var(--radius-xs);
      background: var(--warn-bg); color: var(--warn-fg);
      font-variant-numeric: tabular-nums;
    }

    /* ── Top bar ────────────────────────────────────────────── */
    .topbar {
      position: sticky; top: 0; z-index: 40;
      display: flex; align-items: center; justify-content: space-between;
      gap: var(--space-4);
      padding: var(--space-3) var(--space-5);
      background: var(--surface-overlay);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
    }
    .topbar-search {
      display: flex; align-items: center; gap: var(--space-2);
      min-height: 32px;
      padding: 0 var(--space-3); border-radius: var(--radius-sm);
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--fg-faint); font-size: var(--text-sm);
      cursor: pointer;
      transition: border-color var(--motion-fast), color var(--motion-fast);
      min-width: 280px;
    }
    .topbar-search:hover { border-color: var(--border-strong); color: var(--fg-dim); }
    .topbar-search:focus-visible { outline: none; box-shadow: var(--focus-ring); }
    .topbar-search kbd {
      margin-left: auto;
      padding: 1px 6px; border-radius: var(--radius-xs); font-size: 10px;
      background: rgba(255,255,255,0.06); border: 1px solid var(--border);
      color: var(--fg-dim);
      font-family: "JetBrains Mono", monospace;
    }

    /* ── Status pill ────────────────────────────────────────── */
    .status-pill {
      display: inline-flex; align-items: center; gap: 6px;
      min-height: 26px;
      padding: 0 10px; border-radius: var(--radius-xs);
      font-size: 11px; font-weight: 500;
      background: var(--success-bg);
      border: 1px solid var(--success-border);
      color: var(--success-fg);
      cursor: pointer; position: relative;
    }
    .status-pill:focus-visible { outline: none; box-shadow: var(--focus-ring); }
    .status-pill .dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; box-shadow: 0 0 8px currentColor; }
    .status-pill[data-state="degraded"] { background: var(--warn-bg); border-color: var(--warn-border); color: var(--warn-fg); }
    .status-pill[data-state="down"] { background: var(--danger-bg); border-color: var(--danger-border); color: var(--danger-fg); }
    .status-pop {
      position: absolute; top: calc(100% + 8px); right: 0; width: 280px;
      padding: var(--space-3); border-radius: var(--radius-md);
      background: var(--surface-elevated);
      border: 1px solid var(--border-strong);
      box-shadow: var(--shadow-high);
      display: none; z-index: 80;
    }
    .status-pill:hover .status-pop, .status-pill:focus-within .status-pop { display: block; }
    .status-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 6px var(--space-2); border-radius: var(--radius-xs);
      font-size: var(--text-sm); color: var(--fg);
    }
    .status-row + .status-row { border-top: 1px solid var(--border); }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; }
    .dot-ok { background: var(--success); box-shadow: 0 0 8px rgba(74,222,128,0.6); }
    .dot-degraded { background: var(--warn); box-shadow: 0 0 8px rgba(250,204,21,0.6); }
    .dot-down { background: var(--danger); box-shadow: 0 0 8px rgba(248,113,113,0.6); }
    .dot-unknown { background: var(--fg-faint); }

    /* ── Skip link ─────────────────────────────────────────── */
    .skip-link {
      position: absolute; left: -10000px; top: var(--space-2);
      padding: var(--space-2) var(--space-4);
      background: var(--brand); color: var(--brand-fg); font-weight: 600;
      border-radius: var(--radius-md); z-index: 1000;
      text-decoration: none;
    }
    .skip-link:focus { left: var(--space-2); }

    /* ── Toasts ───────────────────────────────────────────── */
    #toast-stack {
      position: fixed; top: var(--space-4); right: var(--space-4); z-index: 100;
      display: flex; flex-direction: column; gap: var(--space-2);
      pointer-events: none;
    }
    .toast {
      pointer-events: auto;
      min-width: 280px; max-width: 380px;
      padding: var(--space-3) var(--space-4);
      border-radius: var(--radius-md);
      background: var(--surface-elevated);
      border: 1px solid var(--border-strong);
      box-shadow: var(--shadow-high);
      font-size: var(--text-sm); color: var(--fg);
      display: flex; align-items: flex-start; gap: var(--space-2);
      animation: toast-in var(--motion-standard) var(--ease-out);
    }
    .toast-success { border-left: 2px solid var(--success); }
    .toast-error   { border-left: 2px solid var(--danger); }
    .toast-info    { border-left: 2px solid var(--brand); }
    @keyframes toast-in { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: none; } }

    /* ── Command palette ──────────────────────────────────── */
    .palette-overlay {
      position: fixed; inset: 0; z-index: 90;
      background: rgba(0,0,0,0.65);
      backdrop-filter: blur(4px);
      display: none; align-items: flex-start; justify-content: center;
      padding-top: 14vh;
    }
    .palette-overlay.open { display: flex; }
    .palette {
      width: 560px; max-width: calc(100vw - 2rem);
      background: var(--surface-elevated);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-high);
      overflow: hidden;
    }
    .palette-input {
      width: 100%; min-height: 48px;
      padding: 0 var(--space-5);
      background: transparent; border: 0; outline: 0;
      color: var(--fg); font-size: var(--text-md);
      border-bottom: 1px solid var(--border);
    }
    .palette-input::placeholder { color: var(--fg-faint); }
    .palette-list { padding: var(--space-2); max-height: 380px; overflow-y: auto; }
    .palette-item {
      display: flex; align-items: center; gap: 10px;
      min-height: 36px;
      padding: var(--space-2) var(--space-3); border-radius: var(--radius-xs);
      color: var(--fg); font-size: var(--text-sm);
      cursor: pointer; text-decoration: none;
    }
    .palette-item:hover, .palette-item[aria-selected="true"] { background: rgba(76,194,255,0.10); }
    .palette-item .hint { margin-left: auto; font-size: 10px; color: var(--fg-faint); }

    /* ── HTMX swap fade ───────────────────────────────────── */
    .htmx-swapping { opacity: 0; transition: opacity var(--motion-standard); }
    .htmx-settling { opacity: 1; transition: opacity var(--motion-standard); }

    details > summary { list-style: none; cursor: pointer; }
    details > summary::-webkit-details-marker { display: none; }

    a { color: var(--brand); text-decoration: none; }
    a:hover { text-decoration: underline; text-underline-offset: 2px; }
    a:focus-visible { outline: none; box-shadow: var(--focus-ring); border-radius: 4px; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.20); }

    /* Skeleton */
    .skeleton {
      background: linear-gradient(90deg, var(--surface), var(--surface-elevated), var(--surface));
      background-size: 200% 100%;
      animation: skeleton 1.6s ease-in-out infinite;
      border-radius: var(--radius-xs);
    }
    @keyframes skeleton { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }

    /* sr-only */
    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
  </style>
</head>
<body class="min-h-full">

<a href="#main-content" class="skip-link">Skip to main content</a>

<div class="layout">
  <aside class="sidebar" aria-label="Primary navigation">
    <a href="/ui/home" class="flex items-center gap-3 px-3 mb-2" aria-label="KAIROS home">
      <div style="width: 28px; height: 28px; border-radius: var(--radius-sm); background: var(--brand); display: grid; place-items: center;" aria-hidden="true">
        <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; color: var(--brand-fg);" fill="none" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 17l4-4 4 4 4-8 6 8" />
        </svg>
      </div>
      <div class="leading-tight">
        <div style="font-size: var(--text-sm); font-weight: 600; letter-spacing: -0.01em;">Kairos</div>
      </div>
    </a>

    <a href="/ui/home" class="sidebar-link" {% if active == 'home' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10h14V10"/></svg>
      Home
    </a>

    <div class="sidebar-section">Capacity</div>
    <a href="/ui/dashboard" class="sidebar-link" {% if active == 'dashboard' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2 4 4 8-8 4 4"/></svg>
      Overview
    </a>
    <a href="/ui/pending" class="sidebar-link" {% if active == 'pending' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Pending
      {% if pending_count and pending_count > 0 %}<span class="badge num" aria-label="{{ pending_count }} pending approvals">{{ pending_count }}</span>{% endif %}
    </a>
    <a href="/ui/workloads" class="sidebar-link" {% if active == 'workloads' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7l8-4 8 4M4 7v10l8 4 8-4V7M4 7l8 4 8-4M12 11v10"/></svg>
      Workloads
    </a>
    <a href="/ui/history" class="sidebar-link" {% if active == 'history' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1018 0 9 9 0 00-18 0zM12 7v5l3 3"/></svg>
      History
    </a>

    <div class="sidebar-section">Observability</div>
    <a href="/ui/keda" class="sidebar-link" {% if active == 'keda' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      KEDA Activity
    </a>
    <a href="/ui/alerts" class="sidebar-link" {% if active == 'alerts' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 6.5h.008v.008H12v-.008zm-9.36-1.81a1.5 1.5 0 011.305-2.252h16.11a1.5 1.5 0 011.305 2.252l-8.055 13.96a1.5 1.5 0 01-2.61 0l-8.055-13.96z"/></svg>
      Alerts
    </a>

    <div class="sidebar-section">System</div>
    <a href="/ui/admin" class="sidebar-link" {% if active == 'admin' %}aria-current="page"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
      Admin
    </a>
    <a href="/docs" class="sidebar-link" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      API Docs<span class="sr-only"> (opens in new tab)</span>
    </a>
    <a href="/metrics" class="sidebar-link" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l4-4 4 4 6-6"/></svg>
      Metrics<span class="sr-only"> (opens in new tab)</span>
    </a>
  </aside>

  <div class="flex flex-col">
    <header class="topbar">
      <button class="topbar-search" id="palette-trigger" aria-label="Open command palette (Cmd+K)">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/>
        </svg>
        <span>Search workloads, runs, decisions…</span>
        <kbd>⌘K</kbd>
      </button>

      <div class="flex items-center gap-2">
        <div id="status-pill" class="status-pill" data-state="ok" tabindex="0" role="button" aria-haspopup="dialog" aria-label="Service health">
          <span class="dot" aria-hidden="true"></span>
          <span id="status-pill-label">All systems</span>
          <div class="status-pop" id="status-pop" role="dialog" aria-label="Service health detail">
            <div class="t-eyebrow" style="padding: 0 var(--space-2) var(--space-1);">Service health</div>
            <div id="status-rows">
              <div class="status-row"><span>loading…</span><span class="status-dot dot-unknown"></span></div>
            </div>
          </div>
        </div>
        <button class="btn btn-icon" id="theme-toggle" aria-label="Toggle theme">
          <svg id="theme-icon" viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </div>
    </header>

    <main id="main-content" class="px-8 py-10 max-w-7xl" tabindex="-1">
      {% block content %}{% endblock %}
    </main>

    <footer class="px-8 py-6 text-center t-caption">
      Kairos · <span class="mono">v0.1.0</span> ·
      <a href="https://github.com/gpadidala/kairos" target="_blank" rel="noopener">github</a> ·
      <a href="/healthz">healthz</a>
    </footer>
  </div>
</div>

<div id="toast-stack" aria-live="polite" aria-atomic="false"></div>

<div class="palette-overlay" id="palette-overlay" role="dialog" aria-label="Command palette" aria-modal="true">
  <div class="palette">
    <input class="palette-input" id="palette-input" placeholder="Type to search workloads, runs, settings…" autocomplete="off" spellcheck="false" aria-label="Command palette search" />
    <div class="palette-list" id="palette-list" role="listbox" aria-label="Commands"></div>
  </div>
</div>

<script>
  (function initTheme(){
    const saved = localStorage.getItem("kairos-theme");
    const sys = window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", saved || sys);
  })();
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const cur = document.documentElement.getAttribute("data-theme") === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", cur);
    localStorage.setItem("kairos-theme", cur);
  });

  async function pollStatus(){
    try {
      const r = await fetch("/api/v1/status", { cache: "no-store" });
      const j = await r.json();
      const pill = document.getElementById("status-pill");
      pill.setAttribute("data-state", j.overall);
      const lbl = { ok: "All systems", degraded: "Degraded", down: "Outage" }[j.overall] || j.overall;
      document.getElementById("status-pill-label").textContent = lbl;
      const rows = j.services.map(s => `
        <div class="status-row">
          <span class="flex items-center gap-2">
            <span class="status-dot ${s.state==='ok'?'dot-ok':s.state==='degraded'?'dot-degraded':s.state==='down'?'dot-down':'dot-unknown'}" aria-hidden="true"></span>
            <span>${s.name}</span>
          </span>
          <span class="t-caption mono num">${s.detail || s.state}</span>
        </div>`).join("");
      document.getElementById("status-rows").innerHTML = rows;
    } catch (e) {}
  }
  pollStatus();
  setInterval(pollStatus, 10000);

  window.toast = function(message, kind="info"){
    const stack = document.getElementById("toast-stack");
    const el = document.createElement("div");
    el.className = `toast toast-${kind}`;
    el.setAttribute("role", kind === "error" ? "alert" : "status");
    el.innerHTML = `<svg viewBox="0 0 24 24" class="w-4 h-4 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      ${kind==="success"?'<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>':
        kind==="error"?'<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>':
        '<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'}
    </svg><div>${message}</div>`;
    stack.appendChild(el);
    setTimeout(() => { el.style.opacity="0"; el.style.transform="translateY(-8px)"; el.style.transition="all 200ms"; }, 4500);
    setTimeout(() => el.remove(), 4800);
  };

  const overlay = document.getElementById("palette-overlay");
  const input   = document.getElementById("palette-input");
  const list    = document.getElementById("palette-list");
  const cmds = [
    {label: "Home",              href: "/ui/home",      hint: "g i"},
    {label: "Overview",          href: "/ui/dashboard", hint: "g o"},
    {label: "Pending approvals", href: "/ui/pending",   hint: "g p"},
    {label: "Workloads",         href: "/ui/workloads", hint: "g w"},
    {label: "History",           href: "/ui/history",   hint: "g h"},
    {label: "KEDA Activity",     href: "/ui/keda",      hint: "g k"},
    {label: "Alerts",            href: "/ui/alerts",    hint: "g a"},
    {label: "Admin",             href: "/ui/admin",     hint: "g s"},
    {label: "API Docs",          href: "/docs",         hint: ""},
    {label: "Metrics",           href: "/metrics",      hint: ""},
    {label: "GitHub",            href: "https://github.com/gpadidala/kairos", hint: ""},
  ];
  function renderPalette(filter=""){
    const f = filter.trim().toLowerCase();
    const filtered = f ? cmds.filter(c => c.label.toLowerCase().includes(f)) : cmds;
    list.innerHTML = filtered.map((c,i) => `
      <a class="palette-item" href="${c.href}" role="option" aria-selected="${i===0}" data-i="${i}">
        <svg viewBox="0 0 24 24" class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span>${c.label}</span>
        ${c.hint ? `<span class="hint mono">${c.hint}</span>` : ""}
      </a>`).join("") || `<div class="px-4 py-6 t-body-sm" style="color: var(--fg-faint);">No matches.</div>`;
  }
  function openPalette(){ overlay.classList.add("open"); input.value=""; renderPalette(); setTimeout(()=>input.focus(),20); }
  function closePalette(){ overlay.classList.remove("open"); }
  document.getElementById("palette-trigger")?.addEventListener("click", openPalette);
  overlay.addEventListener("click", e => { if(e.target===overlay) closePalette(); });
  input.addEventListener("input", () => renderPalette(input.value));
  input.addEventListener("keydown", e => {
    if(e.key === "Enter"){ const a=list.querySelector(".palette-item"); if(a) a.click(); }
    if(e.key === "Escape"){ closePalette(); }
  });
  document.addEventListener("keydown", e => {
    if((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k"){
      e.preventDefault(); overlay.classList.contains("open") ? closePalette() : openPalette();
    }
    if(e.key === "Escape" && overlay.classList.contains("open")) closePalette();
  });

  document.addEventListener("htmx:afterRequest", e => {
    const url = e.detail?.requestConfig?.path || "";
    if(url.includes("/approve") && e.detail.successful){ window.toast("Approved · PR triggered", "success"); }
    if(url.includes("/reject")  && e.detail.successful){ window.toast("Rejected", "info"); }
    if(url.includes("/api/v1/runs") && e.detail.successful){ window.toast("Pipeline run triggered", "success"); }
    if(!e.detail.successful){ window.toast("Request failed — see console", "error"); }
  });
</script>

</body>
</html>
