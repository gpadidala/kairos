{% extends "base.html.j2" %}
{% set active = "pending" %}
{% block title %}Pending Approvals{% endblock %}
{% block content %}

<header class="flex items-end justify-between mb-8" style="gap: var(--space-4);">
  <div>
    <h1 class="t-h1" style="margin: 0;">Pending approvals</h1>
    <p class="t-body" style="color: var(--fg-dim); margin: var(--space-2) 0 0;">
      <span class="num">{{ items | length }}</span> decision{{ '' if items|length == 1 else 's' }} awaiting human approval. Approving opens a GitOps PR.
    </p>
  </div>
  <button
    hx-get="/ui/pending"
    hx-target="body"
    hx-select="main"
    hx-swap="outerHTML"
    class="btn btn-sm"
    aria-label="Refresh approvals list">
    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M4 20l16-16" />
    </svg>
    Refresh
  </button>
</header>

{% if not items %}
  <div class="glass" style="padding: var(--space-8); text-align: center;">
    <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-emerald-400/30 to-blue-400/30 grid place-items-center ring-1 ring-white/10" style="margin-bottom: var(--space-3);" aria-hidden="true">
      <svg viewBox="0 0 24 24" class="w-8 h-8" style="color: var(--success);" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <p class="t-h3" style="margin: 0;">All caught up</p>
    <p class="t-body-sm" style="color: var(--fg-dim); margin: var(--space-2) 0 0;">No pending approvals. Kairos will queue new ones after the next pipeline run.</p>
    <p class="mono t-caption" style="margin-top: var(--space-2);">POST /api/v1/runs</p>
  </div>
{% endif %}

<div class="space-y-5">
{% for a in items %}
  {%- set d = a.decision -%}
  {%- set advice = a.advice -%}
  {%- set cost = d.cost -%}
  <article id="approval-{{ a.id }}" class="glass-strong" style="padding: var(--space-5);"
           aria-labelledby="approval-{{ a.id }}-title">
    <header class="flex items-start justify-between" style="gap: var(--space-5);">
      <div class="flex-1 min-w-0">
        <div class="flex items-center flex-wrap" style="gap: var(--space-2); margin-bottom: var(--space-2);">
          <span class="pill {% if d.severity.value == 'critical' %}pill-danger{% elif d.severity.value == 'warning' %}pill-warn{% else %}pill-info{% endif %}">
            <span class="w-1.5 h-1.5 rounded-full" style="background: currentColor;" aria-hidden="true"></span>
            {{ d.severity.value }}
          </span>
          <span class="pill pill-mono">{{ d.action.value }}</span>
          <span class="pill pill-mono">{{ d.reason_code }}</span>
        </div>
        <h2 id="approval-{{ a.id }}-title" class="mono t-h2" style="margin: 0; word-break: break-all;">{{ d.workload.uid }}</h2>
        <p class="t-body" style="color: var(--fg-dim); margin: var(--space-2) 0 0;">{{ d.rationale }}</p>
      </div>
      <div style="text-align: right; flex-shrink: 0;">
        <div class="mono t-caption">{{ a.created_at.strftime('%Y-%m-%d %H:%M UTC') }}</div>
        <div class="t-caption" style="margin-top: var(--space-1);">
          confidence
          <span class="num" style="color: var(--fg); font-weight: 600; margin-left: 4px;">{{ "%.2f" | format(d.confidence) }}</span>
        </div>
      </div>
    </header>

    {# Cost — primary visual; reviewers anchor on dollar impact #}
    {% if cost %}
    {% set is_save = cost.direction == 'down' %}
    {% set is_uplift = cost.direction == 'up' %}
    <div style="margin-top: var(--space-4); padding: var(--space-4);
                border-radius: var(--radius-lg);
                background: {% if is_save %}var(--success-bg){% elif is_uplift %}var(--warn-bg){% else %}rgba(255,255,255,0.05){% endif %};
                border: 1px solid {% if is_save %}rgba(52,211,153,0.30){% elif is_uplift %}rgba(251,191,36,0.30){% else %}var(--border){% endif %};">
      <div class="flex items-center" style="gap: var(--space-4); flex-wrap: wrap;">
        <div>
          <div class="t-eyebrow" style="margin-bottom: 4px;">Cost impact · est. {{ cost.currency }}/month</div>
          <div class="num" style="font-size: var(--text-xl); font-weight: 700; line-height: 1; letter-spacing: -0.04em;
                                    color: {% if is_save %}var(--success-fg){% elif is_uplift %}var(--warn-fg){% else %}var(--fg-dim){% endif %};">
            {%- if is_save -%}-${{ "%.0f"|format(cost.delta_monthly|abs) }}/mo
            {%- elif is_uplift -%}+${{ "%.0f"|format(cost.delta_monthly) }}/mo
            {%- else -%}flat{%- endif %}
          </div>
        </div>
        <div class="num mono t-caption" style="margin-left: auto;">
          ${{ "%.0f"|format(cost.current_monthly) }}/mo
          <span style="color: var(--fg-faint);">→</span>
          ${{ "%.0f"|format(cost.projected_monthly) }}/mo
          <span style="color: var(--fg-faint); margin-left: var(--space-2);">({{ "%.1f"|format(cost.delta_percent) }}%)</span>
        </div>
      </div>
      <div class="num mono t-caption" style="margin-top: var(--space-2); width: 100%;">
        rates: ${{ "%.4f"|format(cost.cpu_per_hour) }}/vCPU/h ·
        ${{ "%.4f"|format(cost.mem_gib_per_hour) }}/GiB/h ·
        cpu share ${{ "%.0f"|format(cost.cpu_share_monthly) }}/mo ·
        mem share ${{ "%.0f"|format(cost.mem_share_monthly) }}/mo
      </div>
    </div>
    {% endif %}

    {# Anomaly — high-priority, only when present #}
    {% if advice and advice.anomaly_note %}
    <div role="note" style="margin-top: var(--space-3); padding: var(--space-3) var(--space-4);
                            border-radius: var(--radius-md);
                            background: var(--warn-bg);
                            border-left: 3px solid var(--warn);">
      <div class="flex items-start" style="gap: var(--space-2);">
        <svg viewBox="0 0 24 24" class="w-4 h-4" style="color: var(--warn); flex-shrink: 0; margin-top: 2px;" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 6.5h.008v.008H12v-.008zm-9.36-1.81a1.5 1.5 0 011.305-2.252h16.11a1.5 1.5 0 011.305 2.252l-8.055 13.96a1.5 1.5 0 01-2.61 0l-8.055-13.96z"/>
        </svg>
        <p class="t-body-sm" style="color: var(--warn-fg); margin: 0;"><strong>Anomaly:</strong> {{ advice.anomaly_note }}</p>
      </div>
    </div>
    {% endif %}

    {# Proposed change — diff format #}
    {% if d.target_replicas is not none or d.target_cpu_request or d.target_mem_request %}
    <div class="grid grid-cols-1 md:grid-cols-3" style="gap: var(--space-3); margin-top: var(--space-4);">
      {% if d.target_replicas is not none %}
      <div class="glass" style="padding: var(--space-3) var(--space-4);">
        <div class="t-eyebrow">Replicas</div>
        <div class="num" style="font-size: var(--text-base); margin-top: var(--space-1);">
          <span style="color: var(--fg-faint); text-decoration: line-through;">{{ d.workload.current_replicas }}</span>
          <span style="color: var(--fg-faint); margin: 0 6px;">→</span>
          <span style="color: var(--success-fg); font-weight: 700; font-size: var(--text-lg);">{{ d.target_replicas }}</span>
        </div>
      </div>
      {% endif %}
      {% if d.target_cpu_request %}
      <div class="glass" style="padding: var(--space-3) var(--space-4);">
        <div class="t-eyebrow">CPU request</div>
        <div class="num mono" style="font-size: var(--text-base); margin-top: var(--space-1);">
          <span style="color: var(--fg-faint); text-decoration: line-through;">{{ d.workload.cpu_request }}</span>
          <span style="color: var(--fg-faint); margin: 0 6px;">→</span>
          <span style="color: var(--success-fg); font-weight: 700; font-size: var(--text-lg);">{{ d.target_cpu_request }}</span>
        </div>
      </div>
      {% endif %}
      {% if d.target_mem_request %}
      <div class="glass" style="padding: var(--space-3) var(--space-4);">
        <div class="t-eyebrow">Memory</div>
        <div class="num mono" style="font-size: var(--text-base); margin-top: var(--space-1);">
          <span style="color: var(--fg-faint); text-decoration: line-through;">{{ d.workload.mem_request }}</span>
          <span style="color: var(--fg-faint); margin: 0 6px;">→</span>
          <span style="color: var(--success-fg); font-weight: 700; font-size: var(--text-lg);">{{ d.target_mem_request }}</span>
        </div>
      </div>
      {% endif %}
    </div>
    {% endif %}

    {# Cost framing — narrative #}
    {% if advice and advice.cost_commentary %}
    <div class="glass" style="margin-top: var(--space-3); padding: var(--space-4);">
      <div class="flex items-center" style="gap: var(--space-2); margin-bottom: var(--space-1);">
        <span class="t-eyebrow">Cost framing</span>
        <span class="pill {% if advice.cost_tag == 'savings' %}pill-success{% elif advice.cost_tag == 'uplift' %}pill-warn{% else %}pill-info{% endif %}">{{ advice.cost_tag }}</span>
      </div>
      <p class="t-body-sm" style="color: var(--fg-dim); margin: 0;">{{ advice.cost_commentary }}</p>
    </div>
    {% endif %}

    {# Forecasts (collapsed) #}
    {% if d.forecasts %}
    <details style="margin-top: var(--space-3);">
      <summary class="t-caption" style="display: inline-flex; align-items: center; gap: var(--space-1);">
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        View forecasts (<span class="num">{{ d.forecasts | length }}</span>)
      </summary>
      <div class="glass num mono" style="margin-top: var(--space-2); padding: var(--space-3); font-size: var(--text-xs); color: var(--fg-dim);">
        {% for f in d.forecasts %}
        <div>metric=<span style="color: var(--info-fg);">{{ f.metric }}</span> model={{ f.model_used.value }} p95={{ "%.3f" | format(f.p95_predicted) }} peak={{ "%.3f" | format(f.peak_predicted) }} confidence={{ "%.2f" | format(f.confidence_score) }}</div>
        {% endfor %}
      </div>
    </details>
    {% endif %}

    {# Full LLM advice (collapsed) #}
    {% if advice %}
    <details style="margin-top: var(--space-2);">
      <summary class="t-caption" style="display: inline-flex; align-items: center; gap: var(--space-1);">
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        Full LLM advice ({{ advice.provider_used.value }}, <span class="num">{{ advice.tokens_used }}</span> tokens)
      </summary>
      <div style="margin-top: var(--space-3); padding-left: var(--space-4); border-left: 2px solid rgba(96,165,250,0.30);">
        <p class="t-body-sm" style="margin: 0 0 var(--space-3); color: var(--fg-dim);"><strong style="color: var(--fg);">Why:</strong> {{ advice.why }}</p>
        <p class="t-body-sm" style="margin: 0 0 var(--space-3); color: var(--fg-dim);"><strong style="color: var(--fg);">Horizontal vs vertical:</strong> {{ advice.horizontal_vs_vertical }}</p>
        <p class="t-body-sm" style="margin: 0; color: var(--fg-dim);"><strong style="color: var(--fg);">Risk of inaction:</strong> {{ advice.risks_of_inaction }}</p>
      </div>
    </details>
    {% endif %}

    {# Action footer — Approve is primary, Reject secondary #}
    <footer class="flex items-center justify-end flex-wrap" style="gap: var(--space-3); margin-top: var(--space-5);">
      <form
        hx-post="/ui/approvals/{{ a.id }}/reject"
        hx-target="#approval-{{ a.id }}"
        hx-swap="outerHTML swap:200ms"
        class="flex items-center" style="gap: var(--space-2);">
        <input type="hidden" name="approved_by" value="ui-user" />
        <label class="sr-only" for="reason-{{ a.id }}">Rejection reason for {{ d.workload.uid }}</label>
        <input type="text" name="reason" id="reason-{{ a.id }}" placeholder="Rejection reason"
               class="glass-input" style="width: 220px; min-height: 36px; font-size: var(--text-xs);" />
        <button class="btn btn-sm btn-danger" aria-label="Reject {{ d.workload.uid }}">
          <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Reject
        </button>
      </form>
      <form
        hx-post="/ui/approvals/{{ a.id }}/approve"
        hx-target="#approval-{{ a.id }}"
        hx-swap="outerHTML swap:200ms"
        hx-confirm="Approve this scaling decision? A GitOps PR will be opened.">
        <input type="hidden" name="approved_by" value="ui-user" />
        <button class="btn btn-success" aria-label="Approve {{ d.workload.uid }} and open PR">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Approve &amp; open PR
        </button>
      </form>
    </footer>
  </article>
{% endfor %}
</div>
{% endblock %}
