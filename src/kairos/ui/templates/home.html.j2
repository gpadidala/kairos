{% extends "base.html.j2" %}
{% set active = "home" %}
{% block title %}Home{% endblock %}
{% block content %}

{# ── Hero ─────────────────────────────────────────────────────────── #}
<div class="relative mb-12 overflow-hidden rounded-3xl glass-strong">
  <div class="absolute inset-0 -z-10 opacity-50"
       style="background:
         radial-gradient(600px 400px at 15% 20%, rgba(110,168,255,0.40), transparent 60%),
         radial-gradient(700px 500px at 90% 30%, rgba(180,90,255,0.30), transparent 60%),
         radial-gradient(500px 400px at 60% 110%, rgba(255,110,180,0.25), transparent 60%);"></div>
  <div class="px-8 py-12 md:py-16 md:px-14">
    <div class="flex items-center gap-2 text-xs uppercase tracking-widest text-white/55 mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(52,211,153,0.7)]"></span>
      Predictive Capacity & Autoscaling Platform · v0.1.0 · {{ settings.environment }}
    </div>
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-4 leading-tight">
      The right scale<br>
      <span class="bg-gradient-to-r from-blue-300 via-cyan-300 to-emerald-300 bg-clip-text text-transparent">at the right moment.</span>
    </h1>
    <p class="text-lg md:text-xl text-white/75 leading-relaxed max-w-3xl mb-8">
      Kairos forecasts workload load <span class="text-white font-semibold">48 hours</span> ahead,
      surfaces the change for human review, and opens the GitOps PR — so
      KEDA never has to react to a cliff that was already on the timetable.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/ui/dashboard" class="btn-glass btn-glass-success">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2 4 4 8-8 4 4"/></svg>
        Open Overview
      </a>
      <a href="#demo" class="btn-glass">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round"/></svg>
        See the demo
      </a>
      <a href="#architecture" class="btn-glass">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7l9-4 9 4v10l-9 4-9-4V7zM12 11v10M3 7l9 4 9-4"/></svg>
        Architecture
      </a>
      {% if grafana_url %}
      <a href="{{ grafana_url }}" target="_blank" rel="noopener" class="btn-glass">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7v7M10 14L21 3M21 14v7h-7M3 10V3h7M3 10l11 11"/></svg>
        Grafana
      </a>
      {% endif %}
      <a href="/ui/admin" class="btn-glass">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Admin setup
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-10 max-w-3xl">
      <div>
        <div class="text-3xl font-bold tracking-tight">48h</div>
        <div class="text-[11px] uppercase tracking-widest text-white/55 mt-1">forecast horizon</div>
      </div>
      <div>
        <div class="text-3xl font-bold tracking-tight">14d</div>
        <div class="text-[11px] uppercase tracking-widest text-white/55 mt-1">historical lookback</div>
      </div>
      <div>
        <div class="text-3xl font-bold tracking-tight">8</div>
        <div class="text-[11px] uppercase tracking-widest text-white/55 mt-1">decision rules</div>
      </div>
      <div>
        <div class="text-3xl font-bold tracking-tight">5min</div>
        <div class="text-[11px] uppercase tracking-widest text-white/55 mt-1">alert eval cadence</div>
      </div>
    </div>
  </div>
</div>

{# ── What it is ──────────────────────────────────────────────────── #}
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-14">
  <div class="md:col-span-2 glass p-6">
    <div class="text-xs uppercase tracking-widest text-white/55 mb-2">What Kairos is</div>
    <p class="text-base text-white/80 leading-relaxed mb-4">
      Kairos is a <span class="text-white font-semibold">predictive</span> control plane that sits on top of KEDA.
      Where KEDA reacts to load <em>right now</em>, Kairos asks <em>what does this workload look like in 48 hours?</em> —
      runs Prophet (or a statistical fallback) on Mimir-stored metrics, applies deterministic decision rules,
      and either emits a NOOP or queues a <span class="text-white">human-approved</span> GitOps PR
      against your manifests. Reviewers approve in this UI; KEDA continues to handle the second-by-second response.
    </p>
    <div class="flex flex-wrap gap-2 text-[11px]">
      <span class="pill pill-info">Python 3.12</span>
      <span class="pill pill-info">FastAPI · HTMX</span>
      <span class="pill pill-info">Prophet</span>
      <span class="pill pill-info">SQLAlchemy async</span>
      <span class="pill pill-info">Pydantic v2</span>
      <span class="pill pill-info">PromQL</span>
      <span class="pill pill-info">Grafana Provisioning API</span>
      <span class="pill pill-info">PyGithub</span>
    </div>
  </div>
  <div class="glass p-6">
    <div class="text-xs uppercase tracking-widest text-white/55 mb-2">Greek root</div>
    <div class="font-bold text-2xl mb-1">καιρός</div>
    <div class="text-sm text-white/70 leading-relaxed">
      <em>Kairos</em> means “the right moment” — opportune timing, as opposed to <em>chronos</em> (clock time).
      The platform's whole job is to recognize the right moment to scale, before the cliff.
    </div>
  </div>
</div>

{# ── Architecture ────────────────────────────────────────────────── #}
<div id="architecture" class="mb-14 scroll-mt-24">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-white/55">Architecture</h2>
    <span class="text-xs text-white/45">data flow · top to bottom</span>
  </div>
  <div class="glass-strong p-6 md:p-10 overflow-x-auto">
    <svg viewBox="0 0 880 520" class="w-full max-w-4xl mx-auto" font-family="Inter, sans-serif">
      <defs>
        <linearGradient id="g-aks" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#fbbf24"/><stop offset="100%" stop-color="#f97316"/>
        </linearGradient>
        <linearGradient id="g-mimir" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#a78bfa"/><stop offset="100%" stop-color="#e879f9"/>
        </linearGradient>
        <linearGradient id="g-grafana" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#fb7185"/><stop offset="100%" stop-color="#f472b6"/>
        </linearGradient>
        <linearGradient id="g-kairos" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#60a5fa"/><stop offset="100%" stop-color="#22d3ee"/>
        </linearGradient>
        <linearGradient id="g-github" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#94a3b8"/><stop offset="100%" stop-color="#64748b"/>
        </linearGradient>
        <marker id="arrow" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto">
          <path d="M0,0 L8,3 L0,6 Z" fill="rgba(255,255,255,0.55)"/>
        </marker>
        <filter id="soft" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="6" result="coloredBlur"/>
          <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>

      {# Row 1 — Cluster + KEDA #}
      <g transform="translate(40,30)">
        <rect width="320" height="100" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(251,191,36,0.45)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(251,191,36,0.85)" font-weight="600" letter-spacing="2">AKS / GKE / EKS CLUSTER</text>
        <rect x="20" y="42" width="135" height="42" rx="10" fill="url(#g-aks)" filter="url(#soft)"/>
        <text x="87.5" y="68" font-size="13" fill="white" font-weight="600" text-anchor="middle">Workloads</text>
        <rect x="170" y="42" width="135" height="42" rx="10" fill="url(#g-aks)" opacity="0.85"/>
        <text x="237.5" y="62" font-size="13" fill="white" font-weight="600" text-anchor="middle">KEDA</text>
        <text x="237.5" y="76" font-size="9" fill="rgba(255,255,255,0.85)" text-anchor="middle">reactive (NOW)</text>
      </g>

      {# Right of row 1 — Alloy collector #}
      <g transform="translate(420,55)">
        <rect width="160" height="50" rx="12" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.20)"/>
        <text x="80" y="22" font-size="11" fill="rgba(255,255,255,0.55)" text-anchor="middle">collector</text>
        <text x="80" y="38" font-size="14" fill="white" font-weight="600" text-anchor="middle">Alloy / OTel</text>
      </g>

      {# Far right of row 1 — Mimir #}
      <g transform="translate(640,30)">
        <rect width="200" height="100" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(167,139,250,0.45)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(167,139,250,0.90)" font-weight="600" letter-spacing="2">LONG-TERM TSDB</text>
        <rect x="20" y="42" width="160" height="42" rx="10" fill="url(#g-mimir)" filter="url(#soft)"/>
        <text x="100" y="62" font-size="13" fill="white" font-weight="600" text-anchor="middle">Mimir</text>
        <text x="100" y="76" font-size="9" fill="rgba(255,255,255,0.85)" text-anchor="middle">14d+ retention</text>
      </g>

      {# Arrows row 1 #}
      <path d="M360,80 L420,80" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <path d="M580,80 L640,80" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>

      {# Row 2 — Kairos in the middle #}
      <g transform="translate(290,180)">
        <rect width="300" height="120" rx="16" fill="rgba(96,165,250,0.10)" stroke="rgba(96,165,250,0.55)" stroke-width="2"/>
        <text x="150" y="26" font-size="11" fill="rgba(96,165,250,0.95)" font-weight="600" letter-spacing="3" text-anchor="middle">PREDICTIVE CONTROL PLANE</text>
        <rect x="20" y="42" width="260" height="60" rx="12" fill="url(#g-kairos)" filter="url(#soft)"/>
        <text x="150" y="66" font-size="16" fill="white" font-weight="700" text-anchor="middle">KAIROS</text>
        <text x="150" y="82" font-size="9" fill="rgba(255,255,255,0.85)" text-anchor="middle">Prophet · rules R-001..R-008 · approval queue · GitOps</text>
      </g>

      {# Mimir → Kairos #}
      <path d="M740,135 Q740,170 590,210" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="730" y="170" font-size="10" fill="rgba(255,255,255,0.55)" text-anchor="end">PromQL pull</text>

      {# Row 3 — Grafana left, GitHub right, Approvers in middle #}
      <g transform="translate(40,360)">
        <rect width="220" height="90" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(251,113,133,0.45)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(251,113,133,0.95)" font-weight="600" letter-spacing="2">DASHBOARDS · ALERTS</text>
        <rect x="20" y="42" width="180" height="36" rx="10" fill="url(#g-grafana)" filter="url(#soft)"/>
        <text x="110" y="66" font-size="13" fill="white" font-weight="600" text-anchor="middle">Grafana</text>
      </g>

      <g transform="translate(330,360)">
        <rect width="220" height="90" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.25)"/>
        <text x="20" y="28" font-size="11" fill="rgba(255,255,255,0.65)" font-weight="600" letter-spacing="2">HUMAN-IN-THE-LOOP</text>
        <rect x="20" y="42" width="180" height="36" rx="10" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.30)"/>
        <text x="110" y="66" font-size="13" fill="white" font-weight="600" text-anchor="middle">/ui/pending</text>
      </g>

      <g transform="translate(620,360)">
        <rect width="220" height="90" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.55)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(148,163,184,0.95)" font-weight="600" letter-spacing="2">GITOPS · MERGE = APPLY</text>
        <rect x="20" y="42" width="180" height="36" rx="10" fill="url(#g-github)" filter="url(#soft)"/>
        <text x="110" y="66" font-size="13" fill="white" font-weight="600" text-anchor="middle">GitHub PR</text>
      </g>

      {# Kairos → Grafana (provision dashboards + alert rules) #}
      <path d="M380,300 Q260,325 200,360" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="220" y="335" font-size="10" fill="rgba(255,255,255,0.55)">provision</text>

      {# Kairos → /ui/pending #}
      <path d="M440,300 L440,360" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="450" y="335" font-size="10" fill="rgba(255,255,255,0.55)">queue</text>

      {# Approver → GitHub #}
      <path d="M550,405 L620,405" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="585" y="397" font-size="10" fill="rgba(255,255,255,0.55)" text-anchor="middle">approve</text>

      {# Grafana → Kairos webhook (alerts back) #}
      <path d="M150,360 Q150,310 290,260" stroke="rgba(251,113,133,0.50)" stroke-width="1.4" fill="none" marker-end="url(#arrow)" stroke-dasharray="4 4"/>
      <text x="135" y="320" font-size="10" fill="rgba(251,113,133,0.85)">webhook (alerts)</text>

      {# GitHub → AKS via Argo CD #}
      <path d="M730,360 Q800,260 800,150 Q800,40 360,55" stroke="rgba(148,163,184,0.55)" stroke-width="1.4" fill="none" marker-end="url(#arrow)" stroke-dasharray="4 4"/>
      <text x="800" y="240" font-size="10" fill="rgba(148,163,184,0.85)" text-anchor="middle">Argo CD applies</text>

      {# GitHub → Kairos (PR-merged webhook) #}
      <path d="M620,395 Q570,345 590,300" stroke="rgba(148,163,184,0.55)" stroke-width="1.4" fill="none" marker-end="url(#arrow)" stroke-dasharray="4 4"/>
      <text x="615" y="345" font-size="10" fill="rgba(148,163,184,0.85)">PR-merged webhook</text>

      {# Title #}
      <text x="440" y="500" font-size="11" fill="rgba(255,255,255,0.45)" text-anchor="middle">solid = primary flow · dashed = feedback / control loop</text>
    </svg>
  </div>
</div>

{# ── Why Kairos ──────────────────────────────────────────────────── #}
<h2 class="text-sm font-semibold uppercase tracking-widest text-white/55 mb-4">Why Kairos</h2>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 mb-14">
  {% set reasons = [
    {"title":"Predictive, not reactive", "body":"Forecasts 48h ahead so the change lands before the load does. KEDA stays sharp on the minute-by-minute response.", "icon":"M3 12l2-2 4 4 8-8 4 4", "color":"from-blue-400/40 to-cyan-500/40"},
    {"title":"Human-in-the-loop", "body":"Every non-NOOP change is a card a reviewer approves. No surprise scaling decisions in production.", "icon":"M5 13l4 4L19 7", "color":"from-emerald-400/40 to-teal-500/40"},
    {"title":"GitOps native", "body":"Kairos opens a PR — your existing Argo CD / Flux pipeline applies it. The repo stays the source of truth.", "icon":"M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z", "color":"from-violet-400/40 to-fuchsia-500/40"},
    {"title":"Multi-tenant out of box", "body":"Portfolio › Program › Team › App-Code annotations bubble up everywhere. Filter, attribute, audit at every layer.", "icon":"M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M16 3.13a4 4 0 010 7.75M9 11a4 4 0 100-8 4 4 0 000 8z", "color":"from-rose-400/40 to-pink-500/40"},
  ] %}
  {% for r in reasons %}
  <div class="glass p-5">
    <div class="w-10 h-10 rounded-xl bg-gradient-to-br {{ r.color }} grid place-items-center ring-1 ring-white/15 mb-3">
      <svg viewBox="0 0 24 24" class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="{{ r.icon }}"/></svg>
    </div>
    <div class="text-base font-semibold tracking-tight mb-1">{{ r.title }}</div>
    <p class="text-sm text-white/65 leading-relaxed">{{ r.body }}</p>
  </div>
  {% endfor %}
</div>

{# ── Demo walkthrough ────────────────────────────────────────────── #}
<div id="demo" class="mb-14 scroll-mt-24">
  <h2 class="text-sm font-semibold uppercase tracking-widest text-white/55 mb-4">Try the demo · 5 steps</h2>
  <div class="glass-strong p-6">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
      {% set demo = [
        {"n":"1", "title":"Trigger a run", "body":"POST /api/v1/runs with dry_run=true. The pipeline pulls Mimir metrics, runs forecasts, emits decisions.", "cta":"Trigger now", "method":"htmx", "url":"/api/v1/runs"},
        {"n":"2", "title":"Review pending", "body":"Non-NOOP decisions land in the approval queue with rationale + 48h forecast + confidence.", "cta":"Open queue", "method":"link", "url":"/ui/pending"},
        {"n":"3", "title":"Approve", "body":"Approval triggers the GitOps PR (in dry-run, only logged). Argo CD applies the merged manifest in production.", "cta":"How it works", "method":"link", "url":"/ui/history"},
        {"n":"4", "title":"Watch the alert", "body":"Grafana alerts route here via webhook. Firing alerts show on /ui/alerts with Acknowledge.", "cta":"View alerts", "method":"link", "url":"/ui/alerts"},
        {"n":"5", "title":"Resolve", "body":"When load drops, Grafana resolves the alert; the PR-merged webhook closes the approval loop.", "cta":"View activity", "method":"link", "url":"/ui/dashboard"},
      ] %}
      {% for d in demo %}
      <div class="relative">
        <div class="glass p-4 h-full">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-blue-400/40 to-indigo-500/40 grid place-items-center text-xs font-bold text-white ring-1 ring-white/20">{{ d.n }}</span>
            <span class="text-sm font-semibold tracking-tight">{{ d.title }}</span>
          </div>
          <p class="text-[11px] text-white/65 leading-snug mb-3 min-h-[3rem]">{{ d.body }}</p>
          {% if d.method == "htmx" %}
          <button
            hx-post="{{ d.url }}"
            hx-vals='{"dry_run": true}'
            hx-headers='{"Content-Type": "application/json"}'
            hx-swap="none"
            class="btn-glass btn-glass-success btn-glass-sm w-full justify-center">
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12l5 5L20 7"/></svg>
            {{ d.cta }}
          </button>
          {% else %}
          <a href="{{ d.url }}" class="btn-glass btn-glass-sm w-full justify-center">
            {{ d.cta }}
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

{# ── Tool stack ──────────────────────────────────────────────────── #}
<h2 class="text-sm font-semibold uppercase tracking-widest text-white/55 mb-4">Tool stack</h2>
<div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-14">
  {% set tools = [
    {"name": "KEDA",     "subtitle": "reactive autoscaler",      "color": "from-amber-400 to-orange-500",    "detail": "ScaledObjects scale Deployments/StatefulSets/DaemonSets in real time", "href": "/ui/keda",   "external": false},
    {"name": "Mimir",    "subtitle": "long-term TSDB",           "color": "from-indigo-400 to-fuchsia-500",  "detail": "Stores 14d+ of metrics for the PromQL forecasting queries", "href": (grafana_url ~ "/explore?orgId=1") if grafana_url else "https://grafana.com/oss/mimir/", "external": true},
    {"name": "Grafana",  "subtitle": "dashboards + alerting",    "color": "from-rose-400 to-pink-500",       "detail": "Visualizes predictions; routes alerts to Kairos via webhook", "href": grafana_url if grafana_url else "https://grafana.com/", "external": true},
    {"name": "Kairos",   "subtitle": "predictive control plane", "color": "from-blue-400 to-cyan-500",       "detail": "Forecasts, decision rules, approval queue, GitOps automation", "href": "/ui/dashboard", "external": false},
    {"name": "GitHub",   "subtitle": "GitOps source of truth",   "color": "from-slate-400 to-zinc-500",      "detail": "Receives auto-generated PRs editing replicas / requests", "href": github_url if github_url else "https://github.com/", "external": true},
  ] %}
  {% for t in tools %}
  <a href="{{ t.href }}" {% if t.external %}target="_blank" rel="noopener"{% endif %} class="glass p-4 hover:bg-white/[.08] transition-all group block">
    <div class="flex items-start justify-between mb-3">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br {{ t.color }} grid place-items-center ring-1 ring-white/15"></div>
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 text-white/30 group-hover:text-white/60" fill="none" stroke="currentColor" stroke-width="2">
        {% if t.external %}<path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7v7M10 14L21 3"/>{% else %}<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>{% endif %}
      </svg>
    </div>
    <div class="text-base font-semibold tracking-tight">{{ t.name }}</div>
    <div class="text-[10px] uppercase tracking-widest text-white/45 mt-0.5">{{ t.subtitle }}</div>
    <div class="text-[11px] text-white/55 mt-2 leading-snug">{{ t.detail }}</div>
  </a>
  {% endfor %}
</div>

{# ── Quickstart ──────────────────────────────────────────────────── #}
<h2 class="text-sm font-semibold uppercase tracking-widest text-white/55 mb-4">Get started · Docker Compose</h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-14">
  <div class="glass p-5 md:col-span-2">
    <div class="text-xs uppercase tracking-widest text-white/55 mb-2">1. Bring the stack up</div>
    <pre class="mono text-xs bg-black/30 rounded-lg p-3 overflow-x-auto text-white/85 leading-relaxed border border-white/10">git clone https://github.com/gpadidala/kairos.git
cd kairos/deploy/docker-compose
cp .env.example .env   # edit GitHub token, Grafana token, etc.
make up                # docker compose up -d --build
open http://localhost:8090/ui/home</pre>
    <div class="text-xs uppercase tracking-widest text-white/55 mb-2 mt-5">2. Run the pipeline once</div>
    <pre class="mono text-xs bg-black/30 rounded-lg p-3 overflow-x-auto text-white/85 leading-relaxed border border-white/10">curl -X POST http://localhost:8090/api/v1/runs \
  -H 'Content-Type: application/json' \
  -d '{"dry_run": true}'</pre>
  </div>
  <div class="glass p-5">
    <div class="text-xs uppercase tracking-widest text-white/55 mb-3">Bundled services</div>
    <ul class="space-y-2 text-sm text-white/75">
      <li class="flex justify-between"><span>Kairos UI</span><span class="mono text-xs text-white/55">:8090</span></li>
      <li class="flex justify-between"><span>Grafana</span><span class="mono text-xs text-white/55">:3000</span></li>
      <li class="flex justify-between"><span>Mimir</span><span class="mono text-xs text-white/55">:9009</span></li>
      <li class="flex justify-between"><span>Redis</span><span class="mono text-xs text-white/55">:6379</span></li>
    </ul>
    <a href="/ui/admin" class="btn-glass btn-glass-sm w-full justify-center mt-4">
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/></svg>
      Configure connections
    </a>
  </div>
</div>

