{% extends "base.html.j2" %}
{% set active = "home" %}
{% block title %}Home{% endblock %}
{% block content %}

{# ── Hero — one primary CTA, secondaries subordinate ─────────── #}
<section aria-labelledby="hero-title" class="relative mb-12 overflow-hidden rounded-3xl glass-strong">
  <div class="absolute inset-0 -z-10 opacity-50" aria-hidden="true"
       style="background:
         radial-gradient(600px 400px at 15% 20%, rgba(110,168,255,0.40), transparent 60%),
         radial-gradient(700px 500px at 90% 30%, rgba(180,90,255,0.30), transparent 60%),
         radial-gradient(500px 400px at 60% 110%, rgba(255,110,180,0.25), transparent 60%);"></div>

  <div class="px-8 py-12 md:py-16 md:px-14">
    <div class="t-eyebrow flex items-center gap-2" style="margin-bottom: var(--space-4);">
      <span class="w-1.5 h-1.5 rounded-full" style="background: var(--success); box-shadow: 0 0 10px rgba(52,211,153,0.7);" aria-hidden="true"></span>
      Predictive Capacity & Autoscaling Platform · v0.1.0 · {{ settings.environment }}
    </div>
    <h1 id="hero-title" class="t-display" style="margin: 0 0 var(--space-3); max-width: 18ch;">
      The right scale,<br>
      <span style="background: linear-gradient(90deg, #93c5fd, #67e8f9, #6ee7b7); -webkit-background-clip: text; background-clip: text; color: transparent;">at the right moment.</span>
    </h1>
    <p class="t-body" style="max-width: 60ch; color: var(--fg-dim); margin: 0 0 var(--space-6);">
      Kairos forecasts workload load <strong style="color: var(--fg);">48 hours</strong> ahead,
      surfaces the change for human review, and opens the GitOps PR — so KEDA never has to react
      to a cliff that was already on the timetable.
    </p>

    <div class="flex flex-wrap items-center" style="gap: var(--space-3);">
      <a href="/ui/dashboard" class="btn btn-primary">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2 4 4 8-8 4 4"/></svg>
        Open Overview
      </a>
      <a href="#demo" class="btn btn-sm">See the demo</a>
      <a href="#architecture" class="btn btn-sm">Architecture</a>
      <a href="/ui/admin" class="btn btn-sm">Admin setup</a>
    </div>

    <dl class="grid grid-cols-2 md:grid-cols-4 mt-10" style="gap: var(--space-5); max-width: 56rem;">
      <div>
        <dd class="num" style="font-size: var(--text-2xl); font-weight: 700; line-height: 1; letter-spacing: -0.04em;">48h</dd>
        <dt class="t-eyebrow" style="margin-top: var(--space-2);">forecast horizon</dt>
      </div>
      <div>
        <dd class="num" style="font-size: var(--text-2xl); font-weight: 700; line-height: 1; letter-spacing: -0.04em;">14d</dd>
        <dt class="t-eyebrow" style="margin-top: var(--space-2);">historical lookback</dt>
      </div>
      <div>
        <dd class="num" style="font-size: var(--text-2xl); font-weight: 700; line-height: 1; letter-spacing: -0.04em;">8</dd>
        <dt class="t-eyebrow" style="margin-top: var(--space-2);">decision rules</dt>
      </div>
      <div>
        <dd class="num" style="font-size: var(--text-2xl); font-weight: 700; line-height: 1; letter-spacing: -0.04em;">5min</dd>
        <dt class="t-eyebrow" style="margin-top: var(--space-2);">alert eval cadence</dt>
      </div>
    </dl>
  </div>
</section>

{# ── What it is ──────────────────────────────────────────────────── #}
<section aria-labelledby="what-title" class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-14">
  <div class="md:col-span-2 glass" style="padding: var(--space-5);">
    <div class="t-eyebrow" style="margin-bottom: var(--space-2);" id="what-title">What Kairos is</div>
    <p class="t-body" style="color: var(--fg-dim); margin: 0 0 var(--space-4);">
      Kairos is a <strong style="color: var(--fg);">predictive</strong> control plane that sits on top of KEDA.
      Where KEDA reacts to load <em>right now</em>, Kairos asks <em>what does this workload look like in 48 hours?</em> —
      runs Prophet (or a statistical fallback) on Mimir-stored metrics, applies deterministic decision rules,
      and either emits a NOOP or queues a <span style="color: var(--fg);">human-approved</span> GitOps PR
      against your manifests. Reviewers approve in this UI; KEDA continues to handle the second-by-second response.
    </p>
    <div class="flex flex-wrap" style="gap: var(--space-2);">
      <span class="pill pill-info">Python 3.12</span>
      <span class="pill pill-info">FastAPI · HTMX</span>
      <span class="pill pill-info">Prophet</span>
      <span class="pill pill-info">SQLAlchemy async</span>
      <span class="pill pill-info">Pydantic v2</span>
      <span class="pill pill-info">PromQL</span>
      <span class="pill pill-info">Grafana Provisioning API</span>
      <span class="pill pill-info">PyGithub</span>
    </div>
  </div>
  <div class="glass" style="padding: var(--space-5);">
    <div class="t-eyebrow" style="margin-bottom: var(--space-2);">Greek root</div>
    <div style="font-size: var(--text-xl); font-weight: 700; margin-bottom: var(--space-1);">καιρός</div>
    <p class="t-body-sm" style="color: var(--fg-dim); margin: 0;">
      <em>Kairos</em> means &ldquo;the right moment&rdquo; — opportune timing, as opposed to <em>chronos</em> (clock time).
      The platform&rsquo;s whole job is to recognize the right moment to scale, before the cliff.
    </p>
  </div>
</section>

{# ── Architecture ────────────────────────────────────────────────── #}
<section id="architecture" class="mb-14 scroll-mt-24" aria-labelledby="arch-title">
  <div class="flex items-center justify-between" style="margin-bottom: var(--space-4);">
    <h2 id="arch-title" class="t-h2" style="margin: 0;">Architecture</h2>
    <span class="t-caption">data flow · top to bottom</span>
  </div>
  <div class="glass-strong" style="padding: var(--space-6); overflow-x: auto;">
    {# Per ui-ux-pro-max §10: charts / diagrams need a text alternative #}
    <p class="sr-only">
      Data flow: workloads in AKS / GKE / EKS clusters feed metrics through the Alloy collector
      to Mimir long-term TSDB. Kairos pulls from Mimir, applies forecasting plus decision rules
      R-001 through R-008, then writes alerts and dashboards into Grafana, queues approvals in
      its own UI, and opens GitOps PRs in GitHub. Argo CD applies merged PRs back to the cluster.
      Grafana fires alerts back into Kairos via webhook; GitHub fires a PR-merged webhook to
      close the loop.
    </p>
    <svg viewBox="0 0 880 520" class="w-full max-w-4xl mx-auto" font-family="Inter, sans-serif" role="img" aria-label="System architecture diagram (text summary above)">
      <defs>
        <linearGradient id="g-aks" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#fbbf24"/><stop offset="100%" stop-color="#f97316"/></linearGradient>
        <linearGradient id="g-mimir" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#a78bfa"/><stop offset="100%" stop-color="#e879f9"/></linearGradient>
        <linearGradient id="g-grafana" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#fb7185"/><stop offset="100%" stop-color="#f472b6"/></linearGradient>
        <linearGradient id="g-kairos" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#60a5fa"/><stop offset="100%" stop-color="#22d3ee"/></linearGradient>
        <linearGradient id="g-github" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#94a3b8"/><stop offset="100%" stop-color="#64748b"/></linearGradient>
        <marker id="arrow" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto">
          <path d="M0,0 L8,3 L0,6 Z" fill="rgba(255,255,255,0.55)"/>
        </marker>
      </defs>

      <g transform="translate(40,30)">
        <rect width="320" height="100" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(251,191,36,0.45)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(251,191,36,0.85)" font-weight="600" letter-spacing="2">AKS / GKE / EKS CLUSTER</text>
        <rect x="20" y="42" width="135" height="42" rx="10" fill="url(#g-aks)"/>
        <text x="87.5" y="68" font-size="13" fill="white" font-weight="600" text-anchor="middle">Workloads</text>
        <rect x="170" y="42" width="135" height="42" rx="10" fill="url(#g-aks)" opacity="0.85"/>
        <text x="237.5" y="62" font-size="13" fill="white" font-weight="600" text-anchor="middle">KEDA</text>
        <text x="237.5" y="76" font-size="9" fill="rgba(255,255,255,0.85)" text-anchor="middle">reactive (NOW)</text>
      </g>

      <g transform="translate(420,55)">
        <rect width="160" height="50" rx="12" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.20)"/>
        <text x="80" y="22" font-size="11" fill="rgba(255,255,255,0.55)" text-anchor="middle">collector</text>
        <text x="80" y="38" font-size="14" fill="white" font-weight="600" text-anchor="middle">Alloy / OTel</text>
      </g>

      <g transform="translate(640,30)">
        <rect width="200" height="100" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(167,139,250,0.45)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(167,139,250,0.90)" font-weight="600" letter-spacing="2">LONG-TERM TSDB</text>
        <rect x="20" y="42" width="160" height="42" rx="10" fill="url(#g-mimir)"/>
        <text x="100" y="62" font-size="13" fill="white" font-weight="600" text-anchor="middle">Mimir</text>
        <text x="100" y="76" font-size="9" fill="rgba(255,255,255,0.85)" text-anchor="middle">14d+ retention</text>
      </g>

      <path d="M360,80 L420,80" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <path d="M580,80 L640,80" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>

      <g transform="translate(290,180)">
        <rect width="300" height="120" rx="16" fill="rgba(96,165,250,0.10)" stroke="rgba(96,165,250,0.55)" stroke-width="2"/>
        <text x="150" y="26" font-size="11" fill="rgba(96,165,250,0.95)" font-weight="600" letter-spacing="3" text-anchor="middle">PREDICTIVE CONTROL PLANE</text>
        <rect x="20" y="42" width="260" height="60" rx="12" fill="url(#g-kairos)"/>
        <text x="150" y="66" font-size="16" fill="white" font-weight="700" text-anchor="middle">KAIROS</text>
        <text x="150" y="82" font-size="9" fill="rgba(255,255,255,0.85)" text-anchor="middle">Prophet · rules R-001..R-008 · approval queue · GitOps</text>
      </g>

      <path d="M740,135 Q740,170 590,210" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="730" y="170" font-size="10" fill="rgba(255,255,255,0.55)" text-anchor="end">PromQL pull</text>

      <g transform="translate(40,360)">
        <rect width="220" height="90" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(251,113,133,0.45)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(251,113,133,0.95)" font-weight="600" letter-spacing="2">DASHBOARDS · ALERTS</text>
        <rect x="20" y="42" width="180" height="36" rx="10" fill="url(#g-grafana)"/>
        <text x="110" y="66" font-size="13" fill="white" font-weight="600" text-anchor="middle">Grafana</text>
      </g>

      <g transform="translate(330,360)">
        <rect width="220" height="90" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.25)"/>
        <text x="20" y="28" font-size="11" fill="rgba(255,255,255,0.65)" font-weight="600" letter-spacing="2">HUMAN-IN-THE-LOOP</text>
        <rect x="20" y="42" width="180" height="36" rx="10" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.30)"/>
        <text x="110" y="66" font-size="13" fill="white" font-weight="600" text-anchor="middle">/ui/pending</text>
      </g>

      <g transform="translate(620,360)">
        <rect width="220" height="90" rx="14" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.55)" stroke-width="1.5"/>
        <text x="20" y="28" font-size="11" fill="rgba(148,163,184,0.95)" font-weight="600" letter-spacing="2">GITOPS · MERGE = APPLY</text>
        <rect x="20" y="42" width="180" height="36" rx="10" fill="url(#g-github)"/>
        <text x="110" y="66" font-size="13" fill="white" font-weight="600" text-anchor="middle">GitHub PR</text>
      </g>

      <path d="M380,300 Q260,325 200,360" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="220" y="335" font-size="10" fill="rgba(255,255,255,0.55)">provision</text>
      <path d="M440,300 L440,360" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="450" y="335" font-size="10" fill="rgba(255,255,255,0.55)">queue</text>
      <path d="M550,405 L620,405" stroke="rgba(255,255,255,0.35)" stroke-width="1.4" fill="none" marker-end="url(#arrow)"/>
      <text x="585" y="397" font-size="10" fill="rgba(255,255,255,0.55)" text-anchor="middle">approve</text>
      <path d="M150,360 Q150,310 290,260" stroke="rgba(251,113,133,0.50)" stroke-width="1.4" fill="none" marker-end="url(#arrow)" stroke-dasharray="4 4"/>
      <text x="135" y="320" font-size="10" fill="rgba(251,113,133,0.85)">webhook (alerts)</text>
      <path d="M730,360 Q800,260 800,150 Q800,40 360,55" stroke="rgba(148,163,184,0.55)" stroke-width="1.4" fill="none" marker-end="url(#arrow)" stroke-dasharray="4 4"/>
      <text x="800" y="240" font-size="10" fill="rgba(148,163,184,0.85)" text-anchor="middle">Argo CD applies</text>
      <path d="M620,395 Q570,345 590,300" stroke="rgba(148,163,184,0.55)" stroke-width="1.4" fill="none" marker-end="url(#arrow)" stroke-dasharray="4 4"/>
      <text x="615" y="345" font-size="10" fill="rgba(148,163,184,0.85)">PR-merged webhook</text>

      <text x="440" y="500" font-size="11" fill="rgba(255,255,255,0.45)" text-anchor="middle">solid = primary flow · dashed = feedback / control loop</text>
    </svg>
  </div>
</section>

{# ── Why Kairos ──────────────────────────────────────────────────── #}
<section aria-labelledby="why-title" class="mb-14">
  <h2 id="why-title" class="t-eyebrow" style="margin-bottom: var(--space-4);">Why Kairos</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4" style="gap: var(--space-3);">
    {% set reasons = [
      {"title":"Predictive, not reactive", "body":"Forecasts 48h ahead so the change lands before the load does. KEDA stays sharp on the minute-by-minute response.", "icon":"M3 12l2-2 4 4 8-8 4 4", "color":"from-blue-400/40 to-cyan-500/40"},
      {"title":"Human-in-the-loop", "body":"Every non-NOOP change is a card a reviewer approves. No surprise scaling decisions in production.", "icon":"M5 13l4 4L19 7", "color":"from-emerald-400/40 to-teal-500/40"},
      {"title":"GitOps native", "body":"Kairos opens a PR — your existing Argo CD / Flux pipeline applies it. The repo stays the source of truth.", "icon":"M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z", "color":"from-violet-400/40 to-fuchsia-500/40"},
      {"title":"Multi-tenant", "body":"Portfolio › Program › Team › App-Code annotations bubble up everywhere. Filter, attribute, audit at every layer.", "icon":"M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M16 3.13a4 4 0 010 7.75M9 11a4 4 0 100-8 4 4 0 000 8z", "color":"from-rose-400/40 to-pink-500/40"},
    ] %}
    {% for r in reasons %}
    <article class="glass" style="padding: var(--space-5);">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br {{ r.color }} grid place-items-center ring-1 ring-white/15" style="margin-bottom: var(--space-3);" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="{{ r.icon }}"/></svg>
      </div>
      <h3 class="t-h3" style="margin: 0 0 var(--space-1);">{{ r.title }}</h3>
      <p class="t-body-sm" style="color: var(--fg-dim); margin: 0;">{{ r.body }}</p>
    </article>
    {% endfor %}
  </div>
</section>

{# ── Demo walkthrough ────────────────────────────────────────────── #}
<section id="demo" class="mb-14 scroll-mt-24" aria-labelledby="demo-title">
  <h2 id="demo-title" class="t-eyebrow" style="margin-bottom: var(--space-4);">Try the demo · 5 steps</h2>
  <div class="glass-strong" style="padding: var(--space-5);">
    <ol class="grid grid-cols-1 md:grid-cols-5" style="gap: var(--space-3); list-style: none; padding: 0; margin: 0;">
      {% set demo = [
        {"n":"1", "title":"Trigger a run", "body":"POST /api/v1/runs with dry_run=true. The pipeline pulls Mimir metrics, runs forecasts, emits decisions.", "cta":"Trigger now", "method":"htmx", "url":"/api/v1/runs"},
        {"n":"2", "title":"Review pending", "body":"Non-NOOP decisions land in the approval queue with rationale + 48h forecast + confidence + cost.", "cta":"Open queue", "method":"link", "url":"/ui/pending"},
        {"n":"3", "title":"Approve", "body":"Approval triggers the GitOps PR. In dry-run it's only logged. Argo CD applies the merged manifest in production.", "cta":"How it works", "method":"link", "url":"/ui/history"},
        {"n":"4", "title":"Watch the alert", "body":"Grafana alerts route here via webhook. Firing alerts show on /ui/alerts with Acknowledge.", "cta":"View alerts", "method":"link", "url":"/ui/alerts"},
        {"n":"5", "title":"Resolve", "body":"When load drops, Grafana resolves the alert; the PR-merged webhook closes the approval loop.", "cta":"View activity", "method":"link", "url":"/ui/dashboard"},
      ] %}
      {% for d in demo %}
      <li class="glass" style="padding: var(--space-4);">
        <div class="flex items-center" style="gap: var(--space-2); margin-bottom: var(--space-2);">
          <span class="num" aria-hidden="true" style="display: grid; place-items: center; width: 28px; height: 28px; border-radius: var(--radius-md); background: linear-gradient(135deg, rgba(96,165,250,0.40), rgba(99,102,241,0.40)); color: white; font-size: var(--text-xs); font-weight: 700; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.20);">{{ d.n }}</span>
          <h3 class="t-h3" style="margin: 0; font-size: var(--text-sm);">{{ d.title }}</h3>
        </div>
        <p class="t-body-sm" style="color: var(--fg-dim); margin: 0 0 var(--space-3); min-height: 3rem;">{{ d.body }}</p>
        {% if d.method == "htmx" %}
        <button
          hx-post="{{ d.url }}"
          hx-vals='{"dry_run": true}'
          hx-headers='{"Content-Type": "application/json"}'
          hx-swap="none"
          class="btn btn-success btn-sm" style="width: 100%;">
          {{ d.cta }}
        </button>
        {% else %}
        <a href="{{ d.url }}" class="btn btn-sm" style="width: 100%;">{{ d.cta }}</a>
        {% endif %}
      </li>
      {% endfor %}
    </ol>
  </div>
</section>

{# ── Tool stack ──────────────────────────────────────────────────── #}
<section aria-labelledby="stack-title" class="mb-14">
  <h2 id="stack-title" class="t-eyebrow" style="margin-bottom: var(--space-4);">Tool stack</h2>
  <div class="grid grid-cols-2 md:grid-cols-5" style="gap: var(--space-3);">
    {% set tools = [
      {"name": "KEDA",     "subtitle": "reactive autoscaler",      "color": "from-amber-400 to-orange-500",    "detail": "ScaledObjects scale Deployments / StatefulSets / DaemonSets in real time", "href": "/ui/keda",   "external": false},
      {"name": "Mimir",    "subtitle": "long-term TSDB",           "color": "from-indigo-400 to-fuchsia-500",  "detail": "Stores 14d+ of metrics for the PromQL forecasting queries", "href": (grafana_url ~ "/explore?orgId=1") if grafana_url else "https://grafana.com/oss/mimir/", "external": true},
      {"name": "Grafana",  "subtitle": "dashboards + alerting",    "color": "from-rose-400 to-pink-500",       "detail": "Visualizes predictions; routes alerts to Kairos via webhook", "href": grafana_url if grafana_url else "https://grafana.com/", "external": true},
      {"name": "Kairos",   "subtitle": "predictive control plane", "color": "from-blue-400 to-cyan-500",       "detail": "Forecasts, decision rules, approval queue, GitOps automation", "href": "/ui/dashboard", "external": false},
      {"name": "GitHub",   "subtitle": "GitOps source of truth",   "color": "from-slate-400 to-zinc-500",      "detail": "Receives auto-generated PRs editing replicas / requests", "href": github_url if github_url else "https://github.com/", "external": true},
    ] %}
    {% for t in tools %}
    <a href="{{ t.href }}" {% if t.external %}target="_blank" rel="noopener"{% endif %}
       class="glass block" style="padding: var(--space-4); text-decoration: none; color: inherit;"
       {% if t.external %}aria-label="{{ t.name }} (opens in new tab)"{% endif %}>
      <div class="flex items-start justify-between" style="margin-bottom: var(--space-3);">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br {{ t.color }} grid place-items-center ring-1 ring-white/15" aria-hidden="true"></div>
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" style="color: var(--fg-faint);" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          {% if t.external %}<path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7v7M10 14L21 3"/>{% else %}<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>{% endif %}
        </svg>
      </div>
      <div class="t-h3" style="margin: 0;">{{ t.name }}</div>
      <div class="t-eyebrow" style="margin-top: var(--space-1);">{{ t.subtitle }}</div>
      <p class="t-body-sm" style="color: var(--fg-dim); margin: var(--space-2) 0 0;">{{ t.detail }}</p>
    </a>
    {% endfor %}
  </div>
</section>

{# ── Quickstart ──────────────────────────────────────────────────── #}
<section aria-labelledby="qs-title" class="mb-14">
  <h2 id="qs-title" class="t-eyebrow" style="margin-bottom: var(--space-4);">Get started · Docker Compose</h2>
  <div class="grid grid-cols-1 md:grid-cols-3" style="gap: var(--space-4);">
    <div class="md:col-span-2 glass" style="padding: var(--space-5);">
      <div class="t-eyebrow" style="margin-bottom: var(--space-2);">1. Bring the stack up</div>
      <pre class="mono" style="font-size: var(--text-xs); background: rgba(0,0,0,0.30); border-radius: var(--radius-md); padding: var(--space-3); overflow-x: auto; color: rgba(255,255,255,0.85); line-height: 1.6; border: 1px solid var(--border); margin: 0;">git clone https://github.com/gpadidala/kairos.git
cd kairos/deploy/docker-compose
cp .env.example .env   # edit GitHub token, Grafana token, etc.
make up                # docker compose up -d --build
open http://localhost:8090/ui/home</pre>

      <div class="t-eyebrow" style="margin: var(--space-5) 0 var(--space-2);">2. Run the pipeline once</div>
      <pre class="mono" style="font-size: var(--text-xs); background: rgba(0,0,0,0.30); border-radius: var(--radius-md); padding: var(--space-3); overflow-x: auto; color: rgba(255,255,255,0.85); line-height: 1.6; border: 1px solid var(--border); margin: 0;">curl -X POST http://localhost:8090/api/v1/runs \
  -H 'Content-Type: application/json' \
  -d '{"dry_run": true}'</pre>
    </div>
    <div class="glass" style="padding: var(--space-5);">
      <div class="t-eyebrow" style="margin-bottom: var(--space-3);">Bundled services</div>
      <ul class="num" style="list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-2);">
        <li class="flex justify-between t-body-sm"><span>Kairos UI</span><span class="mono t-caption">:8090</span></li>
        <li class="flex justify-between t-body-sm"><span>Grafana</span><span class="mono t-caption">:3000</span></li>
        <li class="flex justify-between t-body-sm"><span>Mimir</span><span class="mono t-caption">:9009</span></li>
        <li class="flex justify-between t-body-sm"><span>Redis</span><span class="mono t-caption">:6379</span></li>
      </ul>
      <a href="/ui/admin" class="btn btn-sm" style="width: 100%; margin-top: var(--space-4); justify-content: center;">Configure connections</a>
    </div>
  </div>
</section>

{# ── Details ────────────────────────────────────────────────────── #}
<section aria-labelledby="details-title" class="mb-12">
  <h2 id="details-title" class="t-eyebrow" style="margin-bottom: var(--space-4);">Details</h2>
  <div class="grid grid-cols-1 md:grid-cols-3" style="gap: var(--space-3);">
    {% set details = [
      {"name":"API reference",       "href":"/docs",                                "ext":true,  "body":"FastAPI auto-generated OpenAPI schema — every route, every model. Try-it-now from the browser."},
      {"name":"Source · GitHub",     "href":"https://github.com/gpadidala/kairos",  "ext":true,  "body":"All code, tests, and ADRs. Open issues, send PRs. MIT licensed."},
      {"name":"Prometheus metrics",  "href":"/metrics",                              "ext":true,  "body":"Internal observability — pipeline runtimes, decision counts, PR creation latency, alert ingest rate."},
    ] %}
    {% for d in details %}
    <a href="{{ d.href }}" {% if d.ext %}target="_blank" rel="noopener"{% endif %}
       class="glass block" style="padding: var(--space-5); text-decoration: none; color: inherit;"
       {% if d.ext %}aria-label="{{ d.name }} (opens in new tab)"{% endif %}>
      <div class="flex items-center justify-between" style="margin-bottom: var(--space-2);">
        <div class="t-h3" style="margin: 0;">{{ d.name }}</div>
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" style="color: var(--fg-faint);" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          {% if d.ext %}<path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7v7M10 14L21 3"/>{% else %}<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>{% endif %}
        </svg>
      </div>
      <p class="t-body-sm" style="color: var(--fg-dim); margin: 0;">{{ d.body }}</p>
    </a>
    {% endfor %}
  </div>
</section>

{% endblock %}
