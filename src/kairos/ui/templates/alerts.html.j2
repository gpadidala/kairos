{% extends "base.html.j2" %}
{% set active = "alerts" %}
{% block title %}Alerts{% endblock %}
{% block content %}
<div class="flex items-end justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold tracking-tight mb-1">Alerts</h1>
    <p class="text-sm text-white/55">
      Live from Grafana unified alerting + alerts received via webhook into this app.
    </p>
  </div>
  {% if grafana_url %}
  <a href="{{ grafana_url }}/alerting/list" target="_blank" class="btn-glass btn-glass-sm">
    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7v7m0-7L10 14m-3-7H4a1 1 0 00-1 1v13a1 1 0 001 1h13a1 1 0 001-1v-3"/>
    </svg>
    Open in Grafana
  </a>
  {% endif %}
</div>

<!-- ── Webhook setup ──────────────────────────────────────────── -->
<div class="glass p-5 mb-8">
  <div class="flex items-center gap-2 mb-2">
    <span class="pill pill-info pill-mono">setup</span>
    <h2 class="text-base font-semibold tracking-tight">Webhook URL for Grafana</h2>
  </div>
  <p class="text-sm text-white/65 leading-relaxed mb-3">
    Kairos auto-provisions a contact point named <span class="mono text-blue-300">kairos-webhook</span>
    on startup (when a Grafana API token is configured). If your Grafana isn't bundled, add this URL
    manually as a webhook contact point — Kairos-related alerts will then surface here in real time.
  </p>
  <div class="flex items-center gap-2 mono text-sm">
    <span class="px-3 py-2 rounded-lg bg-black/30 border border-white/10 text-blue-200 break-all flex-1">{{ webhook_url }}</span>
    <button class="btn-glass btn-glass-sm" onclick="navigator.clipboard.writeText('{{ webhook_url }}'); window.toast('Copied', 'success')">
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M8 5a2 2 0 002 2h4a2 2 0 002-2M8 5a2 2 0 012-2h4a2 2 0 012 2"/></svg>
      Copy
    </button>
  </div>
</div>

<!-- ── Firing ────────────────────────────────────────────────── -->
{% if firing %}
<h2 class="text-sm font-semibold uppercase tracking-widest text-white/55 mb-3">
  <span class="text-rose-300">Firing</span> · {{ firing | length }}
</h2>
<div class="space-y-4 mb-10">
  {% for a in firing %}
  <div id="alert-{{ a.id }}" class="glass-strong p-5">
    <div class="flex items-start justify-between gap-6">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <span class="pill pill-danger">
            <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
            firing
          </span>
          <span class="pill pill-mono">{{ a.severity }}</span>
          {% if a.workload_uid %}
            <span class="pill pill-info pill-mono">{{ a.workload_uid }}</span>
          {% endif %}
        </div>
        <h2 class="text-lg font-semibold tracking-tight">{{ a.title }}</h2>
        {% if a.summary %}
          <p class="text-sm text-white/70 mt-1 leading-relaxed">{{ a.summary }}</p>
        {% endif %}
        {% if a.description %}
          <p class="text-xs text-white/50 mt-2 leading-relaxed">{{ a.description }}</p>
        {% endif %}
      </div>
      <div class="text-right text-xs text-white/45 shrink-0">
        {% if a.starts_at %}<div class="mono">since {{ a.starts_at.strftime('%H:%M:%S') }}</div>{% endif %}
        <div class="mono mt-1">received {{ a.received_at.strftime('%H:%M:%S') }}</div>
      </div>
    </div>

    <div class="mt-4 flex items-center justify-end gap-2 flex-wrap">
      {% if a.panel_url %}
        <a href="{{ a.panel_url }}" target="_blank" class="btn-glass btn-glass-sm">
          <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7v7m0-7L10 14m-3-7H4a1 1 0 00-1 1v13a1 1 0 001 1h13a1 1 0 001-1v-3"/></svg>
          Open panel
        </a>
      {% endif %}
      <form
        hx-post="/ui/alerts/{{ a.id }}/ack"
        hx-target="#alert-{{ a.id }}"
        hx-swap="outerHTML swap:200ms">
        <input type="hidden" name="acknowledged_by" value="ui-user" />
        <button class="btn-glass btn-glass-sm btn-glass-success">
          <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Acknowledge
        </button>
      </form>
    </div>

    {% if a.labels %}
    <details class="mt-4">
      <summary class="text-xs text-white/55 inline-flex items-center gap-1 hover:text-white/85">
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        Labels
      </summary>
      <div class="mt-2 text-xs mono p-3 rounded-xl glass space-y-1 text-white/75">
        {% for k, v in a.labels.items() %}
          <div><span class="text-blue-300">{{ k }}</span>=<span>{{ v }}</span></div>
        {% endfor %}
      </div>
    </details>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}

<!-- ── Empty state ────────────────────────────────────────────── -->
{% if not firing and not live_alerts %}
  <div class="glass p-16 text-center mb-10">
    <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-emerald-400/30 to-blue-400/30 grid place-items-center ring-1 ring-white/10">
      <svg viewBox="0 0 24 24" class="w-8 h-8 text-emerald-300" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
    </div>
    <p class="text-lg text-white/85 font-medium">No active alerts</p>
    <p class="text-sm text-white/45 mt-1">Cluster is healthy or Grafana hasn't routed alerts here yet.</p>
    <p class="text-xs text-white/35 mt-2 mono">Configure the webhook URL above and trigger a test from Grafana.</p>
  </div>
{% endif %}

<!-- ── Live (Grafana-direct) ────────────────────────────────── -->
{% if live_alerts %}
<h2 class="text-sm font-semibold uppercase tracking-widest text-white/55 mb-3">
  Grafana live · {{ live_alerts | length }}
</h2>
<div class="space-y-3 mb-10">
{% for a in live_alerts %}
  <div class="glass p-4">
    <div class="flex items-center gap-2 mb-1 flex-wrap">
      <span class="pill {% if a.state == 'alerting' %}pill-danger{% elif a.state == 'pending' %}pill-warn{% else %}pill-info{% endif %}">
        <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
        {{ a.state }}
      </span>
      <span class="pill pill-mono">{{ a.severity }}</span>
      <h3 class="font-semibold ml-2">{{ a.title }}</h3>
    </div>
    {% if a.summary %}<p class="text-sm text-white/70 leading-relaxed">{{ a.summary }}</p>{% endif %}
  </div>
{% endfor %}
</div>
{% endif %}

<!-- ── Recent (resolved + acknowledged) ────────────────────── -->
{% if recent %}
<h2 class="text-sm font-semibold uppercase tracking-widest text-white/55 mb-3">
  Recent · {{ recent | length }}
</h2>
<div class="glass overflow-hidden">
  <table class="glass-table">
    <thead>
      <tr><th>State</th><th>Title</th><th>Workload</th><th>Severity</th><th>Resolved</th><th>By</th></tr>
    </thead>
    <tbody>
      {% for a in recent %}
      <tr>
        <td><span class="pill {% if a.state.value == 'resolved' %}pill-success{% else %}pill-info{% endif %}">{{ a.state.value }}</span></td>
        <td class="text-xs">{{ a.title }}</td>
        <td class="mono text-xs">{{ a.workload_uid or '—' }}</td>
        <td class="text-xs">{{ a.severity }}</td>
        <td class="mono text-xs text-white/55">{{ a.ends_at.strftime('%Y-%m-%d %H:%M') if a.ends_at else '—' }}</td>
        <td class="mono text-xs text-white/55">{{ a.acknowledged_by or '—' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}
{% endblock %}
