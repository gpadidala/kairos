{% for f in decision.forecasts %}
- metric={{ f.metric }} model={{ f.model_used }} p95={{ "%.3f"|format(f.p95_predicted) }} peak={{ "%.3f"|format(f.peak_predicted) }} confidence={{ "%.2f"|format(f.confidence_score) }}
{% endfor %}

