- Delta: ${{ "%.2f"|format(decision.cost.delta_monthly) }}/mo ({{ "%.1f"|format(decision.cost.delta_percent) }}%)
- Direction: {{ decision.cost.direction }}
- Rates: ${{ "%.4f"|format(decision.cost.cpu_per_hour) }}/vCPU/h · ${{ "%.4f"|format(decision.cost.mem_gib_per_hour) }}/GiB/h

