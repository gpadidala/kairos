- Runtime: {{ workload.runtime }}
- Tenancy: portfolio={{ workload.portfolio or "—" }} program={{ workload.program or "—" }} team={{ workload.team or "—" }} app_code={{ workload.app_code or "—" }}
- Current replicas: {{ workload.current_replicas }}
- Current requests: cpu={{ workload.cpu_request }}, memory={{ workload.mem_request }}
- Current limits: cpu={{ workload.cpu_limit }}, memory={{ workload.mem_limit }}

- Action: {{ decision.action }}
- Reason: {{ decision.reason_code }}
- Severity: {{ decision.severity }}
- Confidence: {{ "%.2f"|format(decision.confidence) }}
- Proposed changes:
