{% extends "base.html.j2" %}
{% set active = "alerts" %}
{% block title %}Active Alerts{% endblock %}
{% block content %}
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold">Active Alerts</h1>
    <p class="text-sm text-slate-500">Pulled live from Grafana unified alerting.</p>
  </div>
  {% if grafana_url %}
  <a href="{{ grafana_url }}/alerting/list" target="_blank"
     class="text-sm text-blue-600 hover:underline">Open in Grafana →</a>
  {% endif %}
</div>

{% if not alerts %}
  <div class="bg-white rounded-lg border border-slate-200 p-12 text-center text-slate-400">
    <p class="text-lg">No active alerts.</p>
    <p class="text-sm mt-1">Either the cluster is healthy or Grafana is not configured / unreachable.</p>
  </div>
{% endif %}

<div class="space-y-3">
{% for a in alerts %}
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <span class="badge
            {% if a.state == 'alerting' %}bg-rose-100 text-rose-700
            {% elif a.state == 'pending' %}bg-amber-100 text-amber-700
            {% else %}bg-slate-100 text-slate-700{% endif %}">
            {{ a.state }}
          </span>
          <span class="badge bg-slate-100 text-slate-700 mono text-[10px]">{{ a.severity }}</span>
        </div>
        <h2 class="text-lg font-semibold">{{ a.title }}</h2>
        {% if a.summary %}
          <p class="text-sm text-slate-600 mt-1">{{ a.summary }}</p>
        {% endif %}
      </div>
      <div class="text-right text-xs text-slate-500">
        {% if a.starts_at %}<div>Since <span class="mono">{{ a.starts_at }}</span></div>{% endif %}
      </div>
    </div>
    {% if a.labels %}
    <details class="mt-3">
      <summary class="text-xs text-slate-600 cursor-pointer">Labels</summary>
      <div class="mt-2 text-xs mono bg-slate-50 p-2 rounded border border-slate-200">
        {% for k, v in a.labels.items() %}
          <div><strong>{{ k }}</strong>=<span>{{ v }}</span></div>
        {% endfor %}
      </div>
    </details>
    {% endif %}
  </div>
{% endfor %}
</div>
{% endblock %}
