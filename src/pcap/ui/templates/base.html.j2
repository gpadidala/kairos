<!doctype html>
<html lang="en" class="h-full" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark light" />
  <title>{% block title %}PCAP{% endblock %} · PCAP</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    /* ── Theme tokens ──────────────────────────────────────────── */
    :root, [data-theme="dark"] {
      --bg-1: #0a0e1c;
      --bg-2: #15163a;
      --bg-3: #261552;
      --fg: rgba(255,255,255,0.94);
      --fg-dim: rgba(255,255,255,0.62);
      --fg-faint: rgba(255,255,255,0.38);
      --glass: rgba(255,255,255,0.05);
      --glass-strong: rgba(255,255,255,0.09);
      --glass-border: rgba(255,255,255,0.10);
      --glass-border-strong: rgba(255,255,255,0.18);
      --accent: #6ea8ff;
      --grid: rgba(255,255,255,0.04);
    }
    [data-theme="light"] {
      --bg-1: #f8fafc;
      --bg-2: #eef2ff;
      --bg-3: #ede9fe;
      --fg: rgba(15,23,42,0.92);
      --fg-dim: rgba(15,23,42,0.62);
      --fg-faint: rgba(15,23,42,0.42);
      --glass: rgba(255,255,255,0.62);
      --glass-strong: rgba(255,255,255,0.78);
      --glass-border: rgba(15,23,42,0.10);
      --glass-border-strong: rgba(15,23,42,0.18);
      --accent: #4f46e5;
      --grid: rgba(15,23,42,0.04);
    }

    * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; box-sizing: border-box; }
    html, body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
      letter-spacing: -0.011em;
      color: var(--fg);
      min-height: 100%;
    }
    .mono { font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace; }

    body {
      background:
        radial-gradient(900px 600px at 12% -10%, rgba(110,168,255,0.18), transparent 60%),
        radial-gradient(800px 500px at 110% 0%, rgba(180,90,255,0.18), transparent 60%),
        radial-gradient(700px 600px at 50% 110%, rgba(255,110,180,0.10), transparent 60%),
        linear-gradient(180deg, var(--bg-1), var(--bg-2) 40%, var(--bg-3));
      background-attachment: fixed;
    }
    [data-theme="light"] body {
      background:
        radial-gradient(900px 600px at 12% -10%, rgba(99,102,241,0.18), transparent 60%),
        radial-gradient(800px 500px at 110% 0%, rgba(217,70,239,0.14), transparent 60%),
        linear-gradient(180deg, var(--bg-1), var(--bg-2) 50%, var(--bg-3));
    }

    /* ── Glass primitives ──────────────────────────────────────── */
    .glass {
      background: var(--glass);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.30), inset 0 1px 0 rgba(255,255,255,0.06);
      transition: all 220ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .glass:hover { border-color: var(--glass-border-strong); }
    .glass-strong {
      background: var(--glass-strong);
      backdrop-filter: blur(28px) saturate(200%);
      -webkit-backdrop-filter: blur(28px) saturate(200%);
      border: 1px solid var(--glass-border-strong);
      border-radius: 18px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.10);
    }

    /* ── Glass buttons ─────────────────────────────────────────── */
    .btn-glass {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.55rem 1rem; border-radius: 12px;
      font-weight: 500; font-size: 0.875rem; letter-spacing: -0.005em;
      color: var(--fg);
      background: linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.06));
      border: 1px solid var(--glass-border-strong);
      backdrop-filter: blur(18px) saturate(180%);
      -webkit-backdrop-filter: blur(18px) saturate(180%);
      box-shadow: 0 6px 20px rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.20), inset 0 -1px 0 rgba(0,0,0,0.20);
      cursor: pointer;
      transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 180ms, background 180ms;
    }
    .btn-glass:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.10));
      box-shadow: 0 10px 28px rgba(0,0,0,0.32), inset 0 1px 0 rgba(255,255,255,0.30);
    }
    .btn-glass:active { transform: translateY(0); }
    .btn-glass-success {
      background: linear-gradient(180deg, rgba(52,211,153,0.42), rgba(52,211,153,0.18));
      border-color: rgba(52,211,153,0.55);
      box-shadow: 0 6px 20px rgba(52,211,153,0.25), inset 0 1px 0 rgba(255,255,255,0.30);
    }
    .btn-glass-success:hover {
      background: linear-gradient(180deg, rgba(52,211,153,0.55), rgba(52,211,153,0.25));
      box-shadow: 0 10px 28px rgba(52,211,153,0.35), inset 0 1px 0 rgba(255,255,255,0.40);
    }
    .btn-glass-danger {
      background: linear-gradient(180deg, rgba(251,113,133,0.42), rgba(251,113,133,0.18));
      border-color: rgba(251,113,133,0.55);
      box-shadow: 0 6px 20px rgba(251,113,133,0.25), inset 0 1px 0 rgba(255,255,255,0.30);
    }
    .btn-glass-danger:hover {
      background: linear-gradient(180deg, rgba(251,113,133,0.55), rgba(251,113,133,0.25));
      box-shadow: 0 10px 28px rgba(251,113,133,0.35), inset 0 1px 0 rgba(255,255,255,0.40);
    }
    .btn-glass-sm { padding: 0.35rem 0.75rem; font-size: 0.8rem; border-radius: 10px; }
    .btn-icon {
      width: 36px; height: 36px; padding: 0; display: inline-grid; place-items: center;
      border-radius: 10px;
    }

    /* ── Pills / badges ────────────────────────────────────────── */
    .pill {
      display: inline-flex; align-items: center; gap: 0.35rem;
      padding: 0.2rem 0.6rem; border-radius: 9999px;
      font-size: 0.72rem; font-weight: 500; letter-spacing: 0.005em;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.14);
      backdrop-filter: blur(8px);
    }
    .pill-info    { background: rgba(96,165,250,0.16); border-color: rgba(96,165,250,0.35); color: #bfdbfe; }
    .pill-warn    { background: rgba(251,191,36,0.16); border-color: rgba(251,191,36,0.35); color: #fde68a; }
    .pill-danger  { background: rgba(251,113,133,0.16); border-color: rgba(251,113,133,0.40); color: #fecdd3; }
    .pill-success { background: rgba(52,211,153,0.16); border-color: rgba(52,211,153,0.40); color: #a7f3d0; }
    .pill-mono    { font-family: "JetBrains Mono", monospace; font-size: 0.66rem; letter-spacing: 0; }
    [data-theme="light"] .pill-info { color: #1e40af; background: rgba(96,165,250,0.20); }
    [data-theme="light"] .pill-warn { color: #92400e; background: rgba(251,191,36,0.25); }
    [data-theme="light"] .pill-danger { color: #9f1239; background: rgba(251,113,133,0.20); }
    [data-theme="light"] .pill-success { color: #064e3b; background: rgba(52,211,153,0.22); }

    /* ── Inputs ────────────────────────────────────────────────── */
    .glass-input {
      background: rgba(0,0,0,0.20);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 10px; padding: 0.45rem 0.75rem;
      color: var(--fg); font-size: 0.85rem; backdrop-filter: blur(10px);
      transition: border-color 180ms, background 180ms;
    }
    [data-theme="light"] .glass-input { background: rgba(255,255,255,0.50); border-color: rgba(15,23,42,0.14); }
    .glass-input::placeholder { color: var(--fg-faint); }
    .glass-input:focus {
      outline: none; border-color: rgba(110,168,255,0.55);
      background: rgba(0,0,0,0.30); box-shadow: 0 0 0 3px rgba(110,168,255,0.12);
    }

    /* ── Stat numbers ──────────────────────────────────────────── */
    .stat-number {
      font-weight: 700; letter-spacing: -0.04em;
      font-size: 2.25rem; line-height: 1;
      background: linear-gradient(180deg, var(--fg), color-mix(in srgb, var(--fg) 65%, transparent));
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }

    /* ── Tables ────────────────────────────────────────────────── */
    .glass-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .glass-table th {
      font-weight: 500; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--fg-dim); padding: 0.7rem 1rem; text-align: left;
      border-bottom: 1px solid var(--glass-border);
      background: rgba(255,255,255,0.02);
    }
    .glass-table td {
      padding: 0.7rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.85rem; color: var(--fg);
    }
    .glass-table tr:last-child td { border-bottom: none; }
    .glass-table tr:hover td { background: rgba(255,255,255,0.03); }

    /* ── Sidebar layout ────────────────────────────────────────── */
    .layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: 100vh;
    }
    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }

    .sidebar {
      position: sticky; top: 0; height: 100vh;
      padding: 1.25rem 0.75rem;
      background: rgba(11,16,32,0.55);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      border-right: 1px solid var(--glass-border);
      overflow-y: auto;
    }
    [data-theme="light"] .sidebar { background: rgba(255,255,255,0.65); }
    .sidebar-section {
      font-size: 0.65rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.10em;
      color: var(--fg-faint);
      padding: 1rem 0.75rem 0.4rem;
    }
    .sidebar-link {
      display: flex; align-items: center; gap: 0.65rem;
      padding: 0.5rem 0.75rem; border-radius: 10px;
      color: var(--fg-dim); font-size: 0.875rem; font-weight: 500;
      text-decoration: none; transition: all 150ms ease;
    }
    .sidebar-link:hover { color: var(--fg); background: rgba(255,255,255,0.05); text-decoration: none; }
    .sidebar-link.active {
      color: var(--fg);
      background: linear-gradient(90deg, rgba(110,168,255,0.18), rgba(110,168,255,0.04));
      box-shadow: inset 0 0 0 1px rgba(110,168,255,0.30);
    }
    .sidebar-link svg { width: 18px; height: 18px; opacity: 0.85; flex-shrink: 0; }
    .sidebar-link .badge {
      margin-left: auto; font-size: 0.65rem; padding: 1px 6px; border-radius: 6px;
      background: rgba(251,191,36,0.20); color: #fde68a; font-weight: 600;
    }

    /* ── Top bar (inside the content column) ─────────────────── */
    .topbar {
      position: sticky; top: 0; z-index: 40;
      display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      padding: 0.7rem 1.5rem;
      background: rgba(11,16,32,0.55);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      border-bottom: 1px solid var(--glass-border);
    }
    [data-theme="light"] .topbar { background: rgba(255,255,255,0.65); }
    .topbar-search {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.4rem 0.75rem; border-radius: 10px;
      background: rgba(0,0,0,0.18); border: 1px solid var(--glass-border);
      color: var(--fg-dim); font-size: 0.8rem; cursor: pointer;
      transition: all 150ms ease;
      min-width: 280px;
    }
    [data-theme="light"] .topbar-search { background: rgba(255,255,255,0.45); }
    .topbar-search:hover { border-color: var(--glass-border-strong); color: var(--fg); }
    .topbar-search kbd {
      margin-left: auto;
      padding: 1px 6px; border-radius: 5px; font-size: 0.65rem;
      background: rgba(255,255,255,0.10); border: 1px solid var(--glass-border);
      font-family: "JetBrains Mono", monospace;
    }

    /* ── Status pill (in topbar) ─────────────────────────────── */
    .status-pill {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.3rem 0.7rem; border-radius: 9999px;
      font-size: 0.72rem; font-weight: 500;
      background: rgba(52,211,153,0.16);
      border: 1px solid rgba(52,211,153,0.40);
      color: #a7f3d0;
      cursor: pointer; position: relative;
    }
    .status-pill .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; box-shadow: 0 0 10px currentColor; }
    .status-pill[data-state="degraded"] { background: rgba(251,191,36,0.16); border-color: rgba(251,191,36,0.40); color: #fde68a; }
    .status-pill[data-state="down"] { background: rgba(251,113,133,0.16); border-color: rgba(251,113,133,0.40); color: #fecdd3; }
    .status-pop {
      position: absolute; top: calc(100% + 8px); right: 0; width: 280px;
      padding: 0.6rem; border-radius: 12px;
      background: var(--glass-strong);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--glass-border-strong);
      box-shadow: 0 12px 40px rgba(0,0,0,0.35);
      display: none; z-index: 80;
    }
    .status-pill:hover .status-pop, .status-pill:focus .status-pop, .status-pill.open .status-pop { display: block; }
    .status-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.35rem 0.5rem; border-radius: 8px; font-size: 0.78rem; color: var(--fg);
    }
    .status-row + .status-row { border-top: 1px solid rgba(255,255,255,0.06); }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; }
    .dot-ok { background: #34d399; box-shadow: 0 0 8px rgba(52,211,153,0.7); }
    .dot-degraded { background: #fbbf24; box-shadow: 0 0 8px rgba(251,191,36,0.7); }
    .dot-down { background: #fb7185; box-shadow: 0 0 8px rgba(251,113,133,0.7); }
    .dot-unknown { background: rgba(255,255,255,0.30); }

    /* ── Toasts ────────────────────────────────────────────────── */
    #toast-stack {
      position: fixed; top: 1rem; right: 1rem; z-index: 100;
      display: flex; flex-direction: column; gap: 0.5rem;
      pointer-events: none;
    }
    .toast {
      pointer-events: auto;
      min-width: 280px; max-width: 380px;
      padding: 0.7rem 0.9rem;
      border-radius: 12px;
      background: var(--glass-strong);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--glass-border-strong);
      box-shadow: 0 12px 40px rgba(0,0,0,0.35);
      font-size: 0.85rem; color: var(--fg);
      display: flex; align-items: flex-start; gap: 0.6rem;
      animation: toast-in 220ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .toast-success { border-left: 3px solid #34d399; }
    .toast-error   { border-left: 3px solid #fb7185; }
    .toast-info    { border-left: 3px solid #6ea8ff; }
    @keyframes toast-in { from { opacity: 0; transform: translateY(-12px); } to { opacity: 1; transform: none; } }

    /* ── Command palette (Cmd+K) ───────────────────────────────── */
    .palette-overlay {
      position: fixed; inset: 0; z-index: 90;
      background: rgba(0,0,0,0.4);
      backdrop-filter: blur(8px);
      display: none; align-items: flex-start; justify-content: center;
      padding-top: 14vh;
    }
    .palette-overlay.open { display: flex; }
    .palette {
      width: 560px; max-width: calc(100vw - 2rem);
      background: var(--glass-strong);
      backdrop-filter: blur(28px) saturate(200%);
      -webkit-backdrop-filter: blur(28px) saturate(200%);
      border: 1px solid var(--glass-border-strong);
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.45);
      overflow: hidden;
    }
    .palette-input {
      width: 100%; padding: 1rem 1.2rem;
      background: transparent; border: 0; outline: 0;
      color: var(--fg); font-size: 1rem;
      border-bottom: 1px solid var(--glass-border);
    }
    .palette-input::placeholder { color: var(--fg-faint); }
    .palette-list { padding: 0.5rem; max-height: 360px; overflow-y: auto; }
    .palette-item {
      display: flex; align-items: center; gap: 0.7rem;
      padding: 0.55rem 0.8rem; border-radius: 8px;
      color: var(--fg); font-size: 0.875rem;
      cursor: pointer; text-decoration: none;
    }
    .palette-item:hover, .palette-item[aria-selected="true"] { background: rgba(110,168,255,0.18); }
    .palette-item .hint { margin-left: auto; font-size: 0.7rem; color: var(--fg-faint); }

    /* ── Sparkline (inline svg) ───────────────────────────────── */
    .sparkline { display: block; width: 100%; height: 40px; }
    .sparkline path { fill: none; stroke: var(--accent); stroke-width: 1.5; }
    .sparkline-area { fill: rgba(110,168,255,0.18); stroke: none; }

    /* ── HTMX swap fade ────────────────────────────────────────── */
    .htmx-swapping { opacity: 0; transform: translateY(-8px); transition: all 180ms; }
    .htmx-settling { opacity: 1; transform: none; transition: all 220ms; }

    details > summary { list-style: none; cursor: pointer; }
    details > summary::-webkit-details-marker { display: none; }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── Scrollbar ─────────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.10); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.20); }

    /* Loading skeleton */
    .skeleton {
      background: linear-gradient(90deg, rgba(255,255,255,0.04), rgba(255,255,255,0.10), rgba(255,255,255,0.04));
      background-size: 200% 100%;
      animation: skeleton 1.6s ease-in-out infinite;
      border-radius: 6px;
    }
    @keyframes skeleton { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }
  </style>
</head>
<body class="min-h-full">

<div class="layout">
  <!-- ── Sidebar ─────────────────────────────────────────────── -->
  <aside class="sidebar">
    <a href="/ui/dashboard" class="flex items-center gap-3 px-3 mb-4">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-400 to-fuchsia-500 grid place-items-center shadow-lg ring-1 ring-white/20">
        <svg viewBox="0 0 24 24" class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 17l4-4 4 4 4-8 6 8" />
        </svg>
      </div>
      <div class="leading-tight">
        <div class="text-base font-semibold tracking-tight">PCAP</div>
        <div class="text-[10px] uppercase tracking-widest text-white/50">Predictive Capacity</div>
      </div>
    </a>

    <div class="sidebar-section">Capacity</div>
    <a href="/ui/dashboard" class="sidebar-link {% if active == 'dashboard' %}active{% endif %}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2 4 4 8-8 4 4"/></svg>
      Overview
    </a>
    <a href="/ui/pending" class="sidebar-link {% if active == 'pending' %}active{% endif %}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Pending
      {% if pending_count and pending_count > 0 %}<span class="badge">{{ pending_count }}</span>{% endif %}
    </a>
    <a href="/ui/workloads" class="sidebar-link {% if active == 'workloads' %}active{% endif %}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7l8-4 8 4M4 7v10l8 4 8-4V7M4 7l8 4 8-4M12 11v10"/></svg>
      Workloads
    </a>
    <a href="/ui/history" class="sidebar-link {% if active == 'history' %}active{% endif %}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1018 0 9 9 0 00-18 0zM12 7v5l3 3"/></svg>
      History
    </a>

    <div class="sidebar-section">Observability</div>
    <a href="/ui/keda" class="sidebar-link {% if active == 'keda' %}active{% endif %}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      KEDA Activity
    </a>
    <a href="/ui/alerts" class="sidebar-link {% if active == 'alerts' %}active{% endif %}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 6.5h.008v.008H12v-.008zm-9.36-1.81a1.5 1.5 0 011.305-2.252h16.11a1.5 1.5 0 011.305 2.252l-8.055 13.96a1.5 1.5 0 01-2.61 0l-8.055-13.96z"/></svg>
      Alerts
    </a>

    <div class="sidebar-section">System</div>
    <a href="/docs" class="sidebar-link" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      API Docs
    </a>
    <a href="/metrics" class="sidebar-link" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l4-4 4 4 6-6"/></svg>
      Metrics
    </a>
  </aside>

  <!-- ── Main column ─────────────────────────────────────────── -->
  <div class="flex flex-col">
    <header class="topbar">
      <button class="topbar-search" id="palette-trigger" aria-label="Open command palette">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/>
        </svg>
        <span>Search workloads, runs, decisions…</span>
        <kbd>⌘K</kbd>
      </button>

      <div class="flex items-center gap-2">
        <div id="status-pill" class="status-pill" data-state="ok" tabindex="0">
          <span class="dot"></span>
          <span id="status-pill-label">All systems</span>
          <div class="status-pop" id="status-pop">
            <div class="text-[10px] uppercase tracking-widest text-white/50 px-2 pb-1">Service health</div>
            <div id="status-rows" class="space-y-0">
              <div class="status-row"><span>loading…</span><span class="status-dot dot-unknown"></span></div>
            </div>
          </div>
        </div>
        <button class="btn-glass btn-glass-sm btn-icon" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
          <svg id="theme-icon" viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </div>
    </header>

    <main class="px-8 py-8 max-w-7xl">
      {% block content %}{% endblock %}
    </main>

    <footer class="px-8 py-6 text-center text-xs text-white/40">
      PCAP · <span class="mono">v0.1.0</span> ·
      <a class="hover:text-white/70" href="https://github.com/gpadidala/pcap" target="_blank" rel="noopener">github</a> ·
      <a class="hover:text-white/70" href="/healthz">healthz</a>
    </footer>
  </div>
</div>

<!-- ── Toast stack ─────────────────────────────────────────── -->
<div id="toast-stack"></div>

<!-- ── Command palette ─────────────────────────────────────── -->
<div class="palette-overlay" id="palette-overlay">
  <div class="palette">
    <input class="palette-input" id="palette-input" placeholder="Type to search workloads, runs, settings…" autocomplete="off" spellcheck="false" />
    <div class="palette-list" id="palette-list"></div>
  </div>
</div>

<script>
  // ── Theme toggle (persists to localStorage) ─────────────────
  (function initTheme(){
    const saved = localStorage.getItem("pcap-theme");
    const sys = window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", saved || sys);
  })();
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const cur = document.documentElement.getAttribute("data-theme") === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", cur);
    localStorage.setItem("pcap-theme", cur);
  });

  // ── Status pill polling ─────────────────────────────────────
  async function pollStatus(){
    try {
      const r = await fetch("/api/v1/status", { cache: "no-store" });
      const j = await r.json();
      const pill = document.getElementById("status-pill");
      pill.setAttribute("data-state", j.overall);
      const lbl = { ok: "All systems", degraded: "Degraded", down: "Outage" }[j.overall] || j.overall;
      document.getElementById("status-pill-label").textContent = lbl;
      const rows = j.services.map(s => `
        <div class="status-row">
          <span class="flex items-center gap-2">
            <span class="status-dot ${s.state==='ok'?'dot-ok':s.state==='degraded'?'dot-degraded':s.state==='down'?'dot-down':'dot-unknown'}"></span>
            <span>${s.name}</span>
          </span>
          <span class="text-white/55 mono text-[11px]">${s.detail || s.state}</span>
        </div>`).join("");
      document.getElementById("status-rows").innerHTML = rows;
    } catch (e) { /* keep last known state */ }
  }
  pollStatus();
  setInterval(pollStatus, 10000);

  // ── Toast helper (used by HTMX response code) ──────────────
  window.toast = function(message, kind="info"){
    const stack = document.getElementById("toast-stack");
    const el = document.createElement("div");
    el.className = `toast toast-${kind}`;
    el.innerHTML = `<svg viewBox="0 0 24 24" class="w-4 h-4 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5">
      ${kind==="success"?'<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>':
        kind==="error"?'<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>':
        '<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'}
    </svg><div>${message}</div>`;
    stack.appendChild(el);
    setTimeout(() => { el.style.opacity="0"; el.style.transform="translateY(-12px)"; el.style.transition="all 220ms"; }, 4500);
    setTimeout(() => el.remove(), 4800);
  };

  // ── Command palette ────────────────────────────────────────
  const overlay = document.getElementById("palette-overlay");
  const input   = document.getElementById("palette-input");
  const list    = document.getElementById("palette-list");
  const cmds = [
    {label: "Overview",        href: "/ui/dashboard", hint: "g o"},
    {label: "Pending approvals", href: "/ui/pending",  hint: "g p"},
    {label: "Workloads",       href: "/ui/workloads", hint: "g w"},
    {label: "History",         href: "/ui/history",   hint: "g h"},
    {label: "KEDA Activity",   href: "/ui/keda",      hint: "g k"},
    {label: "Alerts",          href: "/ui/alerts",    hint: "g a"},
    {label: "API Docs",        href: "/docs",         hint: ""},
    {label: "Metrics",         href: "/metrics",      hint: ""},
    {label: "GitHub",          href: "https://github.com/gpadidala/pcap", hint: ""},
  ];
  function renderPalette(filter=""){
    const f = filter.trim().toLowerCase();
    const filtered = f ? cmds.filter(c => c.label.toLowerCase().includes(f)) : cmds;
    list.innerHTML = filtered.map((c,i) => `
      <a class="palette-item" href="${c.href}" aria-selected="${i===0}" data-i="${i}">
        <svg viewBox="0 0 24 24" class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span>${c.label}</span>
        ${c.hint ? `<span class="hint mono">${c.hint}</span>` : ""}
      </a>`).join("") || `<div class="px-4 py-6 text-sm text-white/45">No matches.</div>`;
  }
  function openPalette(){ overlay.classList.add("open"); input.value=""; renderPalette(); setTimeout(()=>input.focus(),20); }
  function closePalette(){ overlay.classList.remove("open"); }
  document.getElementById("palette-trigger")?.addEventListener("click", openPalette);
  overlay.addEventListener("click", e => { if(e.target===overlay) closePalette(); });
  input.addEventListener("input", () => renderPalette(input.value));
  input.addEventListener("keydown", e => {
    if(e.key === "Enter"){ const a=list.querySelector(".palette-item"); if(a) a.click(); }
    if(e.key === "Escape"){ closePalette(); }
  });
  document.addEventListener("keydown", e => {
    if((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k"){
      e.preventDefault(); overlay.classList.contains("open") ? closePalette() : openPalette();
    }
    if(e.key === "Escape" && overlay.classList.contains("open")) closePalette();
  });

  // ── HTMX feedback ──────────────────────────────────────────
  document.addEventListener("htmx:afterRequest", e => {
    const url = e.detail?.requestConfig?.path || "";
    if(url.includes("/approve") && e.detail.successful){ window.toast("Approved · PR triggered", "success"); }
    if(url.includes("/reject")  && e.detail.successful){ window.toast("Rejected", "info"); }
    if(url.includes("/api/v1/runs") && e.detail.successful){ window.toast("Pipeline run triggered", "success"); }
    if(!e.detail.successful){ window.toast("Request failed — see console", "error"); }
  });
</script>

</body>
</html>
