<!doctype html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% block title %}PCAP{% endblock %} · PCAP</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --pcap-bg-1: #0b1020;
      --pcap-bg-2: #1a1240;
      --pcap-bg-3: #2a1260;
      --pcap-glass: rgba(255, 255, 255, 0.06);
      --pcap-glass-strong: rgba(255, 255, 255, 0.10);
      --pcap-glass-border: rgba(255, 255, 255, 0.12);
      --pcap-glass-border-strong: rgba(255, 255, 255, 0.20);
      --pcap-text: rgba(255, 255, 255, 0.92);
      --pcap-text-dim: rgba(255, 255, 255, 0.62);
      --pcap-text-faint: rgba(255, 255, 255, 0.40);
    }

    * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    html, body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "SF Pro Display",
                   "Segoe UI", Roboto, sans-serif;
      letter-spacing: -0.011em;
      color: var(--pcap-text);
    }
    .mono { font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace; }

    /* Animated gradient mesh — Apple Sequoia / wallpaper feel */
    body {
      background:
        radial-gradient(900px 600px at 12% -10%, rgba(110, 168, 255, 0.18), transparent 60%),
        radial-gradient(800px 500px at 110% 0%,  rgba(180, 90, 255, 0.18), transparent 60%),
        radial-gradient(700px 600px at 50% 110%, rgba(255, 110, 180, 0.10), transparent 60%),
        linear-gradient(180deg, var(--pcap-bg-1), var(--pcap-bg-2) 40%, var(--pcap-bg-3));
      background-attachment: fixed;
      min-height: 100vh;
    }
    /* Subtle starfield noise */
    body::before {
      content: "";
      position: fixed; inset: 0;
      background-image:
        radial-gradient(1px 1px at 17% 22%, rgba(255,255,255,0.45), transparent 50%),
        radial-gradient(1px 1px at 73% 67%, rgba(255,255,255,0.30), transparent 50%),
        radial-gradient(1px 1px at 41% 88%, rgba(255,255,255,0.20), transparent 50%),
        radial-gradient(1px 1px at 89% 12%, rgba(255,255,255,0.30), transparent 50%);
      background-size: 220px 220px, 320px 320px, 280px 280px, 360px 360px;
      pointer-events: none;
      opacity: 0.55;
      z-index: 0;
    }
    main { position: relative; z-index: 1; }

    /* ── Glass card ─────────────────────────────────────────────── */
    .glass {
      background: var(--pcap-glass);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--pcap-glass-border);
      border-radius: 16px;
      box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.30),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
      transition: all 220ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .glass:hover { border-color: var(--pcap-glass-border-strong); }
    .glass-strong {
      background: var(--pcap-glass-strong);
      backdrop-filter: blur(28px) saturate(200%);
      -webkit-backdrop-filter: blur(28px) saturate(200%);
      border: 1px solid var(--pcap-glass-border-strong);
      border-radius: 18px;
      box-shadow:
        0 12px 40px rgba(0, 0, 0, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.10);
    }

    /* ── Glass buttons ─────────────────────────────────────────── */
    .btn-glass {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.55rem 1rem;
      border-radius: 12px;
      font-weight: 500;
      letter-spacing: -0.005em;
      font-size: 0.875rem;
      color: var(--pcap-text);
      background: linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.06));
      border: 1px solid var(--pcap-glass-border-strong);
      backdrop-filter: blur(18px) saturate(180%);
      -webkit-backdrop-filter: blur(18px) saturate(180%);
      box-shadow:
        0 6px 20px rgba(0, 0, 0, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.20),
        inset 0 -1px 0 rgba(0, 0, 0, 0.20);
      cursor: pointer;
      transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 180ms, background 180ms;
    }
    .btn-glass:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.10));
      box-shadow:
        0 10px 28px rgba(0, 0, 0, 0.32),
        inset 0 1px 0 rgba(255, 255, 255, 0.30),
        inset 0 -1px 0 rgba(0, 0, 0, 0.20);
    }
    .btn-glass:active { transform: translateY(0); }

    .btn-glass-success {
      background: linear-gradient(180deg, rgba(52, 211, 153, 0.42), rgba(52, 211, 153, 0.18));
      border-color: rgba(52, 211, 153, 0.55);
      box-shadow: 0 6px 20px rgba(52, 211, 153, 0.25),
                  inset 0 1px 0 rgba(255, 255, 255, 0.30),
                  inset 0 -1px 0 rgba(0, 0, 0, 0.18);
    }
    .btn-glass-success:hover {
      background: linear-gradient(180deg, rgba(52, 211, 153, 0.55), rgba(52, 211, 153, 0.25));
      box-shadow: 0 10px 28px rgba(52, 211, 153, 0.35),
                  inset 0 1px 0 rgba(255, 255, 255, 0.40);
    }
    .btn-glass-danger {
      background: linear-gradient(180deg, rgba(251, 113, 133, 0.42), rgba(251, 113, 133, 0.18));
      border-color: rgba(251, 113, 133, 0.55);
      box-shadow: 0 6px 20px rgba(251, 113, 133, 0.25),
                  inset 0 1px 0 rgba(255, 255, 255, 0.30),
                  inset 0 -1px 0 rgba(0, 0, 0, 0.18);
    }
    .btn-glass-danger:hover {
      background: linear-gradient(180deg, rgba(251, 113, 133, 0.55), rgba(251, 113, 133, 0.25));
      box-shadow: 0 10px 28px rgba(251, 113, 133, 0.35),
                  inset 0 1px 0 rgba(255, 255, 255, 0.40);
    }
    .btn-glass-sm { padding: 0.35rem 0.75rem; font-size: 0.8rem; border-radius: 10px; }

    /* Pills / badges */
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.2rem 0.6rem;
      border-radius: 9999px;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.005em;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      backdrop-filter: blur(8px);
    }
    .pill-info    { background: rgba(96, 165, 250, 0.16); border-color: rgba(96,165,250,0.35); color: #bfdbfe; }
    .pill-warn    { background: rgba(251, 191, 36, 0.16); border-color: rgba(251,191,36,0.35); color: #fde68a; }
    .pill-danger  { background: rgba(251, 113, 133, 0.16); border-color: rgba(251,113,133,0.40); color: #fecdd3; }
    .pill-success { background: rgba(52, 211, 153, 0.16); border-color: rgba(52,211,153,0.40); color: #a7f3d0; }
    .pill-mono    { font-family: "JetBrains Mono", monospace; font-size: 0.66rem; letter-spacing: 0; }

    /* Inputs */
    .glass-input {
      background: rgba(0, 0, 0, 0.20);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 10px;
      padding: 0.45rem 0.75rem;
      color: var(--pcap-text);
      font-size: 0.85rem;
      backdrop-filter: blur(10px);
      transition: border-color 180ms, background 180ms;
    }
    .glass-input::placeholder { color: var(--pcap-text-faint); }
    .glass-input:focus {
      outline: none;
      border-color: rgba(110, 168, 255, 0.55);
      background: rgba(0, 0, 0, 0.30);
      box-shadow: 0 0 0 3px rgba(110, 168, 255, 0.12);
    }

    /* Stat number */
    .stat-number {
      font-family: "Inter", sans-serif;
      font-weight: 700;
      letter-spacing: -0.04em;
      font-size: 2.25rem;
      line-height: 1;
      background: linear-gradient(180deg, #ffffff, rgba(255,255,255,0.65));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    /* Tables */
    .glass-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .glass-table th {
      font-weight: 500;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--pcap-text-dim);
      padding: 0.7rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--pcap-glass-border);
    }
    .glass-table td {
      padding: 0.7rem 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      font-size: 0.85rem;
      color: var(--pcap-text);
    }
    .glass-table tr:last-child td { border-bottom: none; }
    .glass-table tr:hover td { background: rgba(255,255,255,0.03); }

    /* Top nav */
    .nav-glass {
      position: sticky; top: 0; z-index: 50;
      background: rgba(11, 16, 32, 0.55);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .nav-link {
      padding: 0.4rem 0.85rem;
      border-radius: 10px;
      color: var(--pcap-text-dim);
      font-size: 0.875rem;
      font-weight: 500;
      transition: all 150ms ease;
      text-decoration: none;
    }
    .nav-link:hover { color: var(--pcap-text); background: rgba(255,255,255,0.05); text-decoration: none; }
    .nav-link.active {
      color: var(--pcap-text);
      background: rgba(255,255,255,0.10);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.10);
    }

    /* HTMX swap fade */
    .htmx-swapping { opacity: 0; transform: translateY(-8px); transition: all 180ms; }
    .htmx-settling { opacity: 1; transform: none; transition: all 220ms; }

    details > summary { list-style: none; cursor: pointer; }
    details > summary::-webkit-details-marker { display: none; }

    a { color: #93c5fd; text-decoration: none; }
    a:hover { color: #bfdbfe; text-decoration: underline; }
  </style>
</head>
<body class="min-h-full">

  <nav class="nav-glass">
    <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
      <a href="/ui/dashboard" class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-400 to-fuchsia-500 grid place-items-center shadow-lg ring-1 ring-white/20">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 17l4-4 4 4 4-8 6 8" />
          </svg>
        </div>
        <div class="leading-tight">
          <div class="text-base font-semibold tracking-tight">PCAP</div>
          <div class="text-[10px] uppercase tracking-widest text-white/50">Predictive Capacity</div>
        </div>
      </a>
      <div class="flex items-center gap-1">
        <a href="/ui/dashboard" class="nav-link {% if active == 'dashboard' %}active{% endif %}">Overview</a>
        <a href="/ui/pending"   class="nav-link {% if active == 'pending'   %}active{% endif %}">Pending</a>
        <a href="/ui/history"   class="nav-link {% if active == 'history'   %}active{% endif %}">History</a>
        <a href="/ui/keda"      class="nav-link {% if active == 'keda'      %}active{% endif %}">KEDA</a>
        <a href="/ui/alerts"    class="nav-link {% if active == 'alerts'    %}active{% endif %}">Alerts</a>
        <a href="/docs"         class="nav-link text-white/40">API</a>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-6 py-8">
    {% block content %}{% endblock %}
  </main>

  <footer class="relative z-10 mt-16 py-8 text-center text-xs text-white/40">
    PCAP · <span class="mono">v0.1.0</span>
    · <a class="hover:text-white/70" href="/metrics">metrics</a>
    · <a class="hover:text-white/70" href="/healthz">healthz</a>
    · <a class="hover:text-white/70" href="/docs">api</a>
  </footer>
</body>
</html>
