{% extends "base.html.j2" %}
{% set active = "workloads" %}
{% block title %}Workloads{% endblock %}
{% block content %}
<div class="flex items-end justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold tracking-tight mb-1">Workloads</h1>
    <p class="text-sm text-white/55">{{ summaries | length }} workload{% if summaries | length != 1 %}s{% endif %} discovered. Click a row to drill in.</p>
  </div>
  <button
    hx-post="/api/v1/runs"
    hx-vals='{"dry_run": true}'
    hx-headers='{"Content-Type": "application/json"}'
    hx-swap="none"
    hx-on::after-request="setTimeout(()=>window.location.reload(),700)"
    class="btn-glass btn-glass-sm">
    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M4 20l16-16" />
    </svg>
    Run pipeline
  </button>
</div>

{% if not summaries %}
  <div class="glass p-16 text-center">
    <p class="text-lg text-white/85 font-medium">No workloads configured</p>
    <p class="text-sm text-white/45 mt-1">Set <span class="mono text-white/70">PCAP_K8S__STATIC_WORKLOADS_FILE</span> or switch to <span class="mono text-white/70">in_cluster</span> mode.</p>
  </div>
{% endif %}

<div class="glass overflow-hidden">
  <table class="glass-table">
    <thead>
      <tr>
        <th>Workload</th>
        <th>Runtime</th>
        <th class="text-right">Replicas</th>
        <th>Resources</th>
        <th>KEDA</th>
        <th>Latest decision</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for s in summaries %}
      {% set w = s.workload %}
      <tr>
        <td>
          <a href="/ui/workloads/{{ w.namespace }}/{{ w.name }}" class="font-semibold tracking-tight">{{ w.name }}</a>
          <div class="text-[11px] text-white/45 mono">{{ w.kind.value }} · {{ w.namespace }}</div>
        </td>
        <td><span class="pill pill-mono">{{ w.runtime.value }}</span></td>
        <td class="text-right mono text-sm">{{ w.current_replicas }}</td>
        <td class="mono text-[11px] text-white/65">
          cpu={{ w.cpu_request }}/{{ w.cpu_limit or '—' }} ·
          mem={{ w.mem_request }}/{{ w.mem_limit or '—' }}
        </td>
        <td class="mono text-[11px]">
          {% if w.keda_scaledobject %}
            <span class="pill pill-info pill-mono">{{ w.keda_scaledobject }}</span>
          {% else %}
            <span class="text-white/30">—</span>
          {% endif %}
        </td>
        <td>
          {% if s.latest %}
            <span class="pill pill-mono
              {% if s.latest.severity == 'critical' %}pill-danger
              {% elif s.latest.severity == 'warning' %}pill-warn
              {% else %}pill-info{% endif %}">{{ s.latest.action }}</span>
            <div class="text-[10px] text-white/40 mono mt-1">{{ s.latest.reason_code }}</div>
          {% else %}
            <span class="text-white/30 text-xs">no decisions yet</span>
          {% endif %}
        </td>
        <td>
          <a href="/ui/workloads/{{ w.namespace }}/{{ w.name }}" class="text-blue-300 hover:text-blue-200 inline-flex items-center gap-1 text-xs">
            details
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
