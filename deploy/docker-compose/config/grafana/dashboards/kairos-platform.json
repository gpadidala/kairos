{
  "uid": "kairos-platform",
  "title": "KAIROS Platform (self-observability)",
  "schemaVersion": 39,
  "version": 0,
  "editable": true,
  "tags": ["kairos", "platform", "self"],
  "timezone": "utc",
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipeline runs (24h)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"refId": "A", "expr": "sum(increase(kairos_pipeline_runs_total[24h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PRs created (24h)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"refId": "A", "expr": "sum(increase(kairos_prs_created_total{result=\"created\"}[24h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Decisions (24h)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"refId": "A", "expr": "sum(increase(kairos_decisions_total[24h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dedup hits (24h)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"refId": "A", "expr": "sum(increase(kairos_dedup_hits_total[24h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Decisions by action",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "expr": "sum by (action) (rate(kairos_decisions_total[5m]))", "legendFormat": "{{action}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pipeline phase duration (p95)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (phase, le) (rate(kairos_pipeline_duration_seconds_bucket[5m])))", "legendFormat": "{{phase}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "LLM tokens (prompt + completion)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "expr": "sum by (provider, kind) (rate(kairos_llm_tokens_total[5m]))", "legendFormat": "{{provider}} {{kind}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Circuit breaker state",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "expr": "kairos_circuit_breaker_state", "legendFormat": "{{service}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 2}}
    }
  ]
}
