# PCAP Docker Compose stack — exact-patch pins.
# Copy to .env and fill in. Never commit .env with real secrets.
#
# INSECURE LAB MODE is on by default (anonymous Grafana, open PCAP API).
# For corporate deploys, set the TOKEN + secrets sections.

# ── Images (pinned; never :latest, never minor-only) ────────────────────
PCAP_IMAGE=ghcr.io/your-org/pcap
PCAP_IMAGE_TAG=0.1.0
REDIS_TAG=7.4-alpine
MIMIR_TAG=2.13.0
GRAFANA_TAG=11.4.0

# ── Corporate proxy (leave blank if no proxy) ───────────────────────────
# Honored both at `docker build` and at runtime inside each container.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.svc,.cluster.local,pcap,redis,mimir,grafana

# ── PCAP configuration ──────────────────────────────────────────────────
PCAP_ENVIRONMENT=prod
PCAP_LOG_LEVEL=INFO
PCAP_API_PORT=8090

# Feature toggles
PCAP_FEATURES_ENABLE_UI=true
PCAP_FEATURES_REQUIRE_UI_APPROVAL=true
PCAP_FEATURES_ENABLE_LLM=false
PCAP_FEATURES_ENABLE_NOTIFICATIONS=false
PCAP_FEATURES_ENABLE_PR_CREATION=false
PCAP_FEATURES_DRY_RUN=true
PCAP_SCHEDULER_ENABLED=true
PCAP_SCHEDULER_INTERVAL_MINUTES=30

# Forecasting
PCAP_FORECASTING_HORIZON_HOURS=48
# 14 for prod; lower for demos / fresh installs where Mimir history is short.
PCAP_FORECASTING_LOOKBACK_DAYS=1
PCAP_FORECASTING_RESOLUTION_SECONDS=60
PCAP_FORECASTING_USE_PROPHET_IF_AVAILABLE=false

# ── External Mimir override ─────────────────────────────────────────────
# Empty = use the bundled Mimir on the "mimir" service. Set to your
# corporate Mimir or Grafana Cloud Prom endpoint otherwise.
PCAP_MIMIR_URL=
PCAP_MIMIR_ORG_ID=
# Bearer token (optional, reads from .secrets/mimir-bearer if present)

# ── Grafana ─────────────────────────────────────────────────────────────
# PCAP_GRAFANA_URL is the SERVER-SIDE URL (the PCAP container uses it for
# API calls). Empty → docker service `http://grafana:3000`.
#
# PCAP_GRAFANA_EXTERNAL_URL is the BROWSER-FACING URL embedded in clickable
# UI links ("Open Grafana" buttons on /ui/alerts and /ui/keda). Default
# http://localhost:3000 so links work from your browser. For corporate
# deploys set to https://grafana.corp.example.com.
PCAP_GRAFANA_URL=
PCAP_GRAFANA_EXTERNAL_URL=http://localhost:3000
# API token reads from .secrets/grafana-api-token if present

# ── GitHub (leave blank to disable real PR creation) ────────────────────
PCAP_GITHUB_REPO=
PCAP_GITHUB_BASE_BRANCH=main
# Token reads from .secrets/github-token if present

# ── LLM (leave blank to disable) ────────────────────────────────────────
PCAP_LLM_PRIMARY=anthropic
# Anthropic / OpenAI keys read from .secrets/{anthropic,openai}-api-key

# ── Redis (dedup) ───────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Mimir (bundled; single-binary mode) ─────────────────────────────────
MIMIR_PORT=9009

# ── Grafana (bundled) ───────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Flip to "false" for corporate deploys that require login
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ROLE=Viewer

# ── API bearer tokens (SHA-256 of accepted tokens; comma-separated) ─────
# Leave blank for open access (INSECURE — LAB ONLY)
PCAP_API_TOKEN_SHA256_LIST=

# ── Resource limits (per container) ─────────────────────────────────────
PCAP_MEM_LIMIT=2g
PCAP_CPU_LIMIT=2
MIMIR_MEM_LIMIT=2g
GRAFANA_MEM_LIMIT=1g
REDIS_MEM_LIMIT=512m
