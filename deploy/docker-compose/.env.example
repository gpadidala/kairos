# KAIROS Docker Compose stack — exact-patch pins.
# Copy to .env and fill in. Never commit .env with real secrets.
#
# INSECURE LAB MODE is on by default (anonymous Grafana, open KAIROS API).
# For corporate deploys, set the TOKEN + secrets sections.

# ── Images (pinned; never :latest, never minor-only) ────────────────────
KAIROS_IMAGE=ghcr.io/your-org/kairos
KAIROS_IMAGE_TAG=0.1.0
REDIS_TAG=7.4-alpine
MIMIR_TAG=2.13.0
GRAFANA_TAG=11.4.0

# ── Corporate proxy (leave blank if no proxy) ───────────────────────────
# Honored both at `docker build` and at runtime inside each container.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.svc,.cluster.local,kairos,redis,mimir,grafana

# ── KAIROS configuration ──────────────────────────────────────────────────
KAIROS_ENVIRONMENT=prod
KAIROS_LOG_LEVEL=INFO
KAIROS_API_PORT=8090

# Feature toggles
KAIROS_FEATURES_ENABLE_UI=true
KAIROS_FEATURES_REQUIRE_UI_APPROVAL=true
KAIROS_FEATURES_ENABLE_LLM=false
KAIROS_FEATURES_ENABLE_NOTIFICATIONS=false
KAIROS_FEATURES_ENABLE_PR_CREATION=false
KAIROS_FEATURES_DRY_RUN=true
KAIROS_SCHEDULER_ENABLED=true
KAIROS_SCHEDULER_INTERVAL_MINUTES=30

# Forecasting
KAIROS_FORECASTING_HORIZON_HOURS=48
# 14 for prod; lower for demos / fresh installs where Mimir history is short.
KAIROS_FORECASTING_LOOKBACK_DAYS=1
KAIROS_FORECASTING_RESOLUTION_SECONDS=60
KAIROS_FORECASTING_USE_PROPHET_IF_AVAILABLE=false

# ── External Mimir override ─────────────────────────────────────────────
# Empty = use the bundled Mimir on the "mimir" service. Set to your
# corporate Mimir or Grafana Cloud Prom endpoint otherwise.
KAIROS_MIMIR_URL=
KAIROS_MIMIR_ORG_ID=
# Bearer token (optional, reads from .secrets/mimir-bearer if present)

# ── Grafana ─────────────────────────────────────────────────────────────
# KAIROS_GRAFANA_URL is the SERVER-SIDE URL (the KAIROS container uses it for
# API calls). Empty → docker service `http://grafana:3000`.
#
# KAIROS_GRAFANA_EXTERNAL_URL is the BROWSER-FACING URL embedded in clickable
# UI links ("Open Grafana" buttons on /ui/alerts and /ui/keda). Default
# http://localhost:3000 so links work from your browser. For corporate
# deploys set to https://grafana.corp.example.com.
KAIROS_GRAFANA_URL=
KAIROS_GRAFANA_EXTERNAL_URL=http://localhost:3000
# API token reads from .secrets/grafana-api-token if present

# ── GitHub (leave blank to disable real PR creation) ────────────────────
KAIROS_GITHUB_REPO=
KAIROS_GITHUB_BASE_BRANCH=main
# Token reads from .secrets/github-token if present

# ── LLM (leave blank to disable) ────────────────────────────────────────
KAIROS_LLM_PRIMARY=anthropic
# Anthropic / OpenAI keys read from .secrets/{anthropic,openai}-api-key

# ── Redis (dedup) ───────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Mimir (bundled; single-binary mode) ─────────────────────────────────
MIMIR_PORT=9009

# ── Grafana (bundled) ───────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Flip to "false" for corporate deploys that require login
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ROLE=Viewer

# ── API bearer tokens (SHA-256 of accepted tokens; comma-separated) ─────
# Leave blank for open access (INSECURE — LAB ONLY)
KAIROS_API_TOKEN_SHA256_LIST=

# ── Resource limits (per container) ─────────────────────────────────────
KAIROS_MEM_LIMIT=2g
KAIROS_CPU_LIMIT=2
MIMIR_MEM_LIMIT=2g
GRAFANA_MEM_LIMIT=1g
REDIS_MEM_LIMIT=512m
